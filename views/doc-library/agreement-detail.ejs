<div class="page-header">
  <h1 class="page-header__title"><%= agreement.user_name %></h1>
  <p class="page-header__subtitle"><%= agreement.agreement_type.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %> — Signed <%= new Date(agreement.signed_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
  <div class="card" style="padding: 1.5rem;">
    <h3 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 1rem; color: var(--primary);">Agreement Text</h3>
    <pre style="white-space: pre-wrap; font-family: var(--font-body); font-size: 0.85rem; line-height: 1.7; background: var(--bg); padding: 1.25rem; border-radius: 8px; border: 1px solid var(--border);"><%= agreement.agreement_text %></pre>
  </div>
  <div>
    <div class="card" style="padding: 1.25rem;">
      <h3 style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.75rem;">Record Details</h3>
      <table style="font-size: 0.85rem; width: 100%;">
        <tr><td style="padding: 0.35rem 0; color: var(--text-muted); width: 100px;">Name</td><td style="padding: 0.35rem 0; font-weight: 600;"><%= agreement.user_name %></td></tr>
        <tr><td style="padding: 0.35rem 0; color: var(--text-muted);">Email</td><td style="padding: 0.35rem 0;"><%= agreement.user_email %></td></tr>
        <tr><td style="padding: 0.35rem 0; color: var(--text-muted);">Type</td><td style="padding: 0.35rem 0;"><%= agreement.agreement_type.replace(/_/g, ' ') %></td></tr>
        <tr><td style="padding: 0.35rem 0; color: var(--text-muted);">Role</td><td style="padding: 0.35rem 0;"><%= agreement.user_type %></td></tr>
        <tr><td style="padding: 0.35rem 0; color: var(--text-muted);">Signed</td><td style="padding: 0.35rem 0;"><%= new Date(agreement.signed_at).toLocaleString() %></td></tr>
        <tr><td style="padding: 0.35rem 0; color: var(--text-muted);">IP Address</td><td style="padding: 0.35rem 0; font-family: monospace; font-size: 0.8rem;"><%= agreement.ip_address || '—' %></td></tr>
        <tr><td style="padding: 0.35rem 0; color: var(--text-muted);">Version</td><td style="padding: 0.35rem 0;">v<%= agreement.agreement_version %></td></tr>
      </table>
    </div>
  </div>
</div>
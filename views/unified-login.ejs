<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg viewBox='0 0 32 32' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z' fill='%232D6A3F'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/admin/static/admin.css">
  <style>
    .unified-login-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #F5F3ED;
      padding: 1rem;
    }
    .unified-login-card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      padding: 2rem;
      width: 100%;
      max-width: 400px;
    }
    .unified-login-header {
      text-align: center;
      margin-bottom: 1.5rem;
    }
    .unified-login-header svg {
      margin-bottom: 0.75rem;
    }
    .unified-login-header h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #1E2418;
      margin: 0;
    }
    .unified-login-header p {
      font-size: 0.85rem;
      color: #5E6B52;
      margin: 0.25rem 0 0;
    }
    .unified-login-form .form-field {
      margin-bottom: 1rem;
    }
    .unified-login-form label {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: #1E2418;
      margin-bottom: 0.3rem;
    }
    .unified-login-form input {
      width: 100%;
      padding: 0.6rem 0.75rem;
      border: 1px solid #D4D1C7;
      border-radius: 6px;
      font-size: 0.9rem;
      background: #FAFAF8;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .unified-login-form input:focus {
      outline: none;
      border-color: #2D6A3F;
      box-shadow: 0 0 0 3px rgba(45, 106, 63, 0.1);
    }
    .unified-login-submit {
      width: 100%;
      padding: 0.65rem;
      background: #2D6A3F;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 0.25rem;
    }
    .unified-login-submit:hover {
      background: #245633;
    }
    .unified-login-footer {
      text-align: center;
      margin-top: 1.25rem;
      font-size: 0.78rem;
      color: #5E6B52;
    }
    .unified-login-footer a {
      color: #2D6A3F;
      text-decoration: none;
    }
    .unified-login-footer a:hover {
      text-decoration: underline;
    }
    .unified-login-divider {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 1.25rem 0;
      font-size: 0.78rem;
      color: #8A9478;
    }
    .unified-login-divider::before,
    .unified-login-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #D6D0C0;
    }
    .google-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      padding: 0.6rem;
      border: 1px solid #D4D1C7;
      border-radius: 6px;
      background: #fff;
      font-size: 0.88rem;
      font-weight: 500;
      color: #1E2418;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }
    .google-btn:hover {
      background: #F5F3ED;
      border-color: #B8B3A8;
      color: #1E2418;
    }
    .google-btn svg {
      width: 18px;
      height: 18px;
    }
    .alert--error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
      padding: 0.6rem 0.75rem;
      border-radius: 6px;
      font-size: 0.82rem;
      margin-bottom: 1rem;
    }
  </style>
</head>
<body class="unified-login-page">
  <div class="unified-login-card">
    <div class="unified-login-header">
      <svg viewBox="0 0 32 32" fill="none" width="44" height="44">
        <path d="M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z" fill="#2D6A3F" opacity="0.9"/>
        <path d="M16 8 L16 24" stroke="#F5F3ED" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M16 14 L12 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M16 14 L20 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M16 18 L11 15.5" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M16 18 L21 15.5" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <h1>Iowa Cannabis Action Network</h1>
      <p>Sign in to your account</p>
    </div>

    <% if (error) { %>
      <div class="alert--error"><%= error %></div>
    <% } %>

    <form method="POST" action="/login" class="unified-login-form">
      <div class="form-field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autofocus placeholder="you@example.com">
      </div>
      <div class="form-field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="Enter your password">
      </div>
      <button type="submit" class="unified-login-submit">Sign In</button>
    </form>

    <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
    <div class="unified-login-divider">or</div>
    <a href="/auth/google" class="google-btn">
      <svg viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
      Sign in with Google
    </a>
    <% } %>

    <div class="unified-login-footer">
      <a href="https://iowacannabisaction.org">&larr; Back to website</a>
    </div>
  </div>
</body>
</html>

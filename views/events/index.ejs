<div class="page-header">
  <div class="page-header__row">
    <div>
      <h1 class="page-header__title">Events</h1>
      <p class="page-header__subtitle">Manage ICAN events and meetings</p>
    </div>
    <div class="page-header__actions">
      <a href="/admin/events/new" class="btn btn--primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Event
      </a>
    </div>
  </div>
</div>

<div class="filters" style="margin-bottom: 1rem">
  <div class="filters__form">
    <a href="/admin/events?filter=upcoming" class="btn <%= filter === 'upcoming' ? 'btn--primary' : 'btn--ghost' %> btn--sm">Upcoming</a>
    <a href="/admin/events?filter=past" class="btn <%= filter === 'past' ? 'btn--primary' : 'btn--ghost' %> btn--sm">Past</a>
    <a href="/admin/events?filter=all" class="btn <%= filter === 'all' ? 'btn--primary' : 'btn--ghost' %> btn--sm">All</a>
  </div>
</div>

<% if (events.length === 0) { %>
  <div class="card">
    <div class="card__body">
      <div class="empty-state">
        <p>No <%= filter %> events. <a href="/admin/events/new">Create one</a></p>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="card">
    <div class="card__body">
      <table class="table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Event</th>
            <th>Type</th>
            <th>Location</th>
            <th>Public</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% events.forEach(ev => {
            const d = new Date(ev.event_date + 'T12:00:00');
            const dateStr = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
          %>
            <tr>
              <td>
                <strong><%= dateStr %></strong>
                <% if (ev.event_time) { %><br><span class="text-muted text-sm"><%= ev.event_time %><% if (ev.end_time) { %> &ndash; <%= ev.end_time %><% } %></span><% } %>
              </td>
              <td>
                <strong><%= ev.title %></strong>
                <% if (ev.description) { %><br><span class="text-muted text-sm"><%= ev.description.substring(0, 80) %><%= ev.description.length > 80 ? '...' : '' %></span><% } %>
              </td>
              <td><span class="badge badge--<%= ev.event_type %>"><%= ev.event_type %></span></td>
              <td class="text-muted text-sm"><%= ev.location || '—' %></td>
              <td><%= ev.is_public ? 'Yes' : 'No' %></td>
              <td class="table__actions">
                <a href="/admin/events/<%= ev.id %>/edit" class="btn btn--ghost btn--sm">Edit</a>
                <form method="POST" action="/admin/events/<%= ev.id %>/delete" onsubmit="return confirm('Delete this event?')" style="display:inline">
                  <button type="submit" class="btn btn--danger btn--sm">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

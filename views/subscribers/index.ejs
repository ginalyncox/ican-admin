<div class="page-header">
  <h1 class="page-header__title">Subscribers</h1>
  <div class="page-header__actions">
    <span class="page-header__stat"><%= activeCount %> active / <%= totalCount %> total</span>
    <a href="/admin/api/subscribers/export" class="btn btn--ghost">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export CSV
    </a>
  </div>
</div>

<!-- Search & Filter -->
<div class="card" style="margin-bottom: 1rem;">
  <div class="card__body">
    <form method="GET" action="/admin/subscribers" style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:flex-end;">
      <div class="form-field" style="flex:1; min-width:200px;">
        <label for="search" style="font-size:0.8rem;">Search</label>
        <input type="text" id="search" name="search" class="form-input" value="<%= search %>" placeholder="Email or name...">
      </div>
      <div class="form-field" style="min-width:140px;">
        <label for="status" style="font-size:0.8rem;">Status</label>
        <select name="status" id="status" class="form-select">
          <option value="">All</option>
          <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
          <option value="unsubscribed" <%= status === 'unsubscribed' ? 'selected' : '' %>>Unsubscribed</option>
        </select>
      </div>
      <div class="form-field" style="min-width:140px;">
        <label for="source" style="font-size:0.8rem;">Source</label>
        <select name="source" id="source" class="form-select">
          <option value="">All</option>
          <% sources.forEach(s => { %>
            <option value="<%= s %>" <%= source === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn--primary btn--sm">Filter</button>
      <% if (search || status || source) { %>
        <a href="/admin/subscribers" class="btn btn--ghost btn--sm">Clear</a>
      <% } %>
    </form>
  </div>
</div>

<!-- Add subscriber -->
<div class="card" style="margin-bottom: 1rem;">
  <div class="card__header">
    <h3 class="card__title">Add Subscriber</h3>
  </div>
  <div class="card__body">
    <form method="POST" action="/admin/subscribers" class="inline-form" style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:flex-end;">
      <div class="form-field">
        <input type="email" name="email" required placeholder="Email address" class="form-input">
      </div>
      <div class="form-field">
        <input type="text" name="name" placeholder="Name (optional)" class="form-input">
      </div>
      <button type="submit" class="btn btn--primary">Add</button>
    </form>
  </div>
</div>

<div class="card">
  <div class="card__body">
    <% if (subscribers.length === 0) { %>
      <p class="empty-state">No subscribers found<%= search || status || source ? ' matching your filters' : '' %>.</p>
    <% } else { %>
      <form method="POST" action="/admin/subscribers/bulk-toggle" id="bulkForm">
        <div style="display:flex; gap:0.5rem; margin-bottom:0.75rem; align-items:center;">
          <label style="font-size:0.8rem; display:flex; align-items:center; gap:0.25rem; cursor:pointer;">
            <input type="checkbox" id="selectAll" onchange="document.querySelectorAll('.sub-check').forEach(c => c.checked = this.checked)">
            Select all
          </label>
          <button type="submit" name="action" value="activate" class="btn btn--ghost btn--sm" onclick="return confirm('Activate selected subscribers?')">Activate Selected</button>
          <button type="submit" name="action" value="deactivate" class="btn btn--ghost btn--sm" onclick="return confirm('Deactivate selected subscribers?')">Deactivate Selected</button>
        </div>

        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th style="width:30px;"></th>
                <th>Email</th>
                <th>Name</th>
                <th>Source</th>
                <th>Status</th>
                <th>Subscribed</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% subscribers.forEach(sub => { %>
                <tr>
                  <td><input type="checkbox" name="ids" value="<%= sub.id %>" class="sub-check"></td>
                  <td><%= sub.email %></td>
                  <td><%= sub.name || '—' %></td>
                  <td><span class="badge badge--source"><%= sub.source %></span></td>
                  <td><span class="badge badge--<%= sub.status === 'active' ? 'published' : 'draft' %>"><%= sub.status %></span></td>
                  <td class="text-muted" style="font-size:0.85rem;"><%= new Date(sub.subscribed_at).toLocaleDateString() %></td>
                  <td class="table__actions">
                    <button type="button" class="btn btn--sm btn--ghost" title="Edit" onclick="
                      var row = this.closest('tr');
                      var editRow = row.nextElementSibling;
                      editRow.style.display = editRow.style.display === 'none' ? 'table-row' : 'none';
                    ">Edit</button>
                    <form method="POST" action="/admin/subscribers/<%= sub.id %>/toggle" style="display:inline">
                      <button type="submit" class="btn btn--sm btn--ghost"><%= sub.status === 'active' ? 'Deactivate' : 'Activate' %></button>
                    </form>
                    <form method="POST" action="/admin/subscribers/<%= sub.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this subscriber?')">
                      <button type="submit" class="btn btn--sm btn--ghost" style="color:var(--danger);">Delete</button>
                    </form>
                  </td>
                </tr>
                <!-- Inline edit row -->
                <tr style="display:none; background:var(--bg-light, #f9f9f6);">
                  <td></td>
                  <td colspan="6">
                    <form method="POST" action="/admin/subscribers/<%= sub.id %>/edit" style="display:flex; gap:0.5rem; align-items:center; padding:0.25rem 0;">
                      <input type="email" name="email" value="<%= sub.email %>" class="form-input" style="flex:1;" required>
                      <input type="text" name="name" value="<%= sub.name || '' %>" class="form-input" style="flex:1;" placeholder="Name">
                      <button type="submit" class="btn btn--primary btn--sm">Save</button>
                      <button type="button" class="btn btn--ghost btn--sm" onclick="this.closest('tr').style.display='none'">Cancel</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </form>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div style="display:flex; justify-content:center; gap:0.25rem; margin-top:1rem;">
          <% if (page > 1) { %>
            <a href="/admin/subscribers?page=<%= page - 1 %>&search=<%= encodeURIComponent(search) %>&status=<%= status %>&source=<%= encodeURIComponent(source) %>" class="btn btn--ghost btn--sm">&laquo; Prev</a>
          <% } %>
          <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
            <a href="/admin/subscribers?page=<%= p %>&search=<%= encodeURIComponent(search) %>&status=<%= status %>&source=<%= encodeURIComponent(source) %>" class="btn btn--sm <%= p === page ? 'btn--primary' : 'btn--ghost' %>"><%= p %></a>
          <% } %>
          <% if (page < totalPages) { %>
            <a href="/admin/subscribers?page=<%= page + 1 %>&search=<%= encodeURIComponent(search) %>&status=<%= status %>&source=<%= encodeURIComponent(source) %>" class="btn btn--ghost btn--sm">Next &raquo;</a>
          <% } %>
        </div>
        <p class="text-muted" style="text-align:center; margin-top:0.5rem; font-size:0.8rem;">
          Showing <%= (page - 1) * 25 + 1 %>–<%= Math.min(page * 25, totalCount) %> of <%= totalCount %>
        </p>
      <% } %>
    <% } %>
  </div>
</div>

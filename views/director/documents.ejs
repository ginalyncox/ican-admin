<div class="page-header">
  <h1 class="page-title">Board Documents</h1>
  <button class="btn btn--primary" onclick="document.getElementById('uploadModal').style.display='flex'">Upload Document</button>
</div>

<!-- Category Filter -->
<div class="director-doc-filters">
  <a href="/director/documents" class="btn btn--<%= !currentCategory ? 'primary' : 'outline' %> btn--sm">All</a>
  <% categories.forEach(c => { %>
    <a href="/director/documents?category=<%= c.category %>" class="btn btn--<%= currentCategory === c.category ? 'primary' : 'outline' %> btn--sm">
      <%= c.category.charAt(0).toUpperCase() + c.category.slice(1) %> (<%= c.count %>)
    </a>
  <% }); %>
</div>

<div class="card">
  <div class="card__body">
    <% if (docs.length === 0) { %>
      <div class="verify-empty">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-light)" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <h3>No documents</h3>
        <p>Upload board documents to share with all directors.</p>
      </div>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Document</th>
            <th>Category</th>
            <th>Uploaded By</th>
            <th>Date</th>
            <th>Size</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% docs.forEach(d => { %>
            <tr>
              <td>
                <div style="display:flex; align-items:center; gap:0.5rem;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <div>
                    <strong><%= d.title %></strong>
                    <% if (d.description) { %><br><span class="text-muted" style="font-size:0.8rem;"><%= d.description %></span><% } %>
                    <% if (d.is_confidential) { %><span class="badge badge--social" style="margin-left:0.25rem; font-size:0.7rem;">Confidential</span><% } %>
                  </div>
                </div>
              </td>
              <td><span class="badge badge--<%= d.category %>"><%= d.category %></span></td>
              <td><%= d.uploaded_by_name || '—' %></td>
              <td class="text-muted"><%= new Date(d.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
              <td class="text-muted"><%= d.file_size ? (d.file_size / 1024).toFixed(0) + ' KB' : '—' %></td>
              <td class="table__actions">
                <a href="/director/documents/<%= d.id %>/download" class="btn btn--outline btn--sm">Download</a>
                <form method="POST" action="/director/documents/<%= d.id %>/delete" style="display:inline;">
                  <button type="submit" class="btn btn--outline btn--sm" style="color:var(--danger);" onclick="return confirm('Delete this document?')">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<!-- Upload Modal -->
<div id="uploadModal" class="modal-overlay" style="display:none;">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Upload Document</h2>
      <button class="modal-close" onclick="this.closest('.modal-overlay').style.display='none'">&times;</button>
    </div>
    <form method="POST" action="/director/documents" enctype="multipart/form-data">
      <div class="form-group">
        <label for="title">Document Title</label>
        <input type="text" id="title" name="title" class="form-control" placeholder="e.g., Q1 2026 Financial Report">
      </div>
      <div class="form-group">
        <label for="description">Description (optional)</label>
        <input type="text" id="description" name="description" class="form-control" placeholder="Brief description">
      </div>
      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category" class="form-control">
          <option value="general">General</option>
          <option value="bylaws">Bylaws</option>
          <option value="policy">Policy</option>
          <option value="financial">Financial</option>
          <option value="legal">Legal</option>
          <option value="minutes">Minutes</option>
          <option value="resolution">Resolution</option>
          <option value="report">Report</option>
          <option value="compliance">Compliance</option>
        </select>
      </div>
      <div class="form-group">
        <label for="file">File</label>
        <input type="file" id="file" name="file" class="form-control" required accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.csv,.png,.jpg,.jpeg">
      </div>
      <div class="form-group">
        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
          <input type="checkbox" name="is_confidential" value="1">
          Mark as confidential
        </label>
      </div>
      <div class="form-actions">
        <button type="button" class="btn btn--outline" onclick="this.closest('.modal-overlay').style.display='none'">Cancel</button>
        <button type="submit" class="btn btn--primary">Upload</button>
      </div>
    </form>
  </div>
</div>

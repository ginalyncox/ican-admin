<div class="page-header">
  <h1 class="page-title">Board Dashboard</h1>
  <p class="page-subtitle">Welcome back, <%= director.name %></p>
</div>

<!-- Quick Stats -->
<div class="stats-grid stats-grid--4">
  <div class="stat-card">
    <div class="stat-card__label">My Attendance</div>
    <div class="stat-card__value"><%= attendanceRate %>%</div>
    <div class="stat-card__detail"><%= myAttendance %> of <%= totalMeetings %> meetings</div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">My Tasks</div>
    <div class="stat-card__value" style="<%= overdueCount > 0 ? 'color:#c0392b' : '' %>"><%= myTasks.length %></div>
    <div class="stat-card__detail"><% if (overdueCount > 0) { %><span style="color:#c0392b"><%= overdueCount %> overdue</span><% } else { %>All on track<% } %> &middot; <a href="/director/tasks">View &rarr;</a></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Open Votes</div>
    <div class="stat-card__value"><%= openVotes.length %></div>
    <div class="stat-card__detail"><a href="/director/votes">View all &rarr;</a></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">COI Status (<%= currentYear %>)</div>
    <div class="stat-card__value"><%= myCoi ? 'Filed' : 'Needed' %></div>
    <div class="stat-card__detail"><a href="/director/coi"><%= myCoi ? 'View disclosure' : 'File now' %> &rarr;</a></div>
  </div>
</div>

<!-- Priority row: Announcements + Tasks -->
<div class="director-grid">
  <!-- Unread Announcements -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Announcements <% if (unreadAnnouncements.length > 0) { %><span class="badge" style="background:#c0392b;color:#fff;font-size:0.7rem;vertical-align:middle;margin-left:4px"><%= unreadAnnouncements.length %> new</span><% } %></h2>
      <a href="/director/announcements" class="btn btn--outline btn--sm">View all</a>
    </div>
    <div class="card__body">
      <% if (unreadAnnouncements.length === 0) { %>
        <p class="text-muted">All caught up — no unread announcements.</p>
      <% } else { %>
        <% unreadAnnouncements.forEach(a => { %>
          <div style="padding:0.5rem 0;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center">
            <div>
              <% if (a.priority === 'urgent') { %><span class="badge" style="background:#c0392b;color:#fff;font-size:0.65rem">URGENT</span> <% } %>
              <% if (a.priority === 'important') { %><span class="badge" style="background:#e67e22;color:#fff;font-size:0.65rem">IMPORTANT</span> <% } %>
              <strong><%= a.title %></strong>
              <div class="text-muted" style="font-size:0.8rem"><%= a.author_name %> &middot; <%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></div>
            </div>
            <form method="POST" action="/director/announcements/<%= a.id %>/read">
              <button type="submit" class="btn btn--outline btn--xs">&#10003;</button>
            </form>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- My Action Items -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">My Action Items <% if (overdueCount > 0) { %><span class="badge" style="background:#c0392b;color:#fff;font-size:0.7rem;vertical-align:middle;margin-left:4px"><%= overdueCount %> overdue</span><% } %></h2>
      <a href="/director/tasks" class="btn btn--outline btn--sm">View all</a>
    </div>
    <div class="card__body">
      <% if (myTasks.length === 0) { %>
        <p class="text-muted">No open tasks assigned to you.</p>
      <% } else { %>
        <% myTasks.forEach(t => { %>
          <%
            const isOverdue = t.due_date && t.due_date < new Date().toISOString().split('T')[0];
            const priorityColors = { urgent: '#c0392b', high: '#e67e22', normal: '#2D6A3F', low: '#7f8c8d' };
          %>
          <div style="padding:0.5rem 0;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center">
            <div>
              <span class="badge" style="background:<%= priorityColors[t.priority] || '#2D6A3F' %>;color:#fff;font-size:0.65rem"><%= t.priority %></span>
              <strong style="<%= isOverdue ? 'color:#c0392b' : '' %>"><%= t.title %></strong>
              <% if (t.due_date) { %>
                <div class="text-muted" style="font-size:0.8rem;<%= isOverdue ? 'color:#c0392b;font-weight:600' : '' %>">
                  Due <%= new Date(t.due_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                  <% if (isOverdue) { %> (OVERDUE)<% } %>
                </div>
              <% } %>
            </div>
            <form method="POST" action="/director/tasks/<%= t.id %>/status">
              <input type="hidden" name="status" value="completed">
              <button type="submit" class="btn btn--outline btn--xs" title="Complete">&#10003;</button>
            </form>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Next Meeting -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Next Meeting</h2>
    </div>
    <div class="card__body">
      <% if (nextMeeting) { %>
        <div class="director-meeting-preview">
          <div class="director-meeting-preview__date">
            <div class="director-meeting-preview__day"><%= new Date(nextMeeting.meeting_date + 'T00:00:00').toLocaleDateString('en-US', { day: 'numeric' }) %></div>
            <div class="director-meeting-preview__month"><%= new Date(nextMeeting.meeting_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short' }) %></div>
          </div>
          <div class="director-meeting-preview__info">
            <h3><a href="/director/meetings/<%= nextMeeting.id %>"><%= nextMeeting.title %></a></h3>
            <% if (nextMeeting.meeting_time) { %><p><%= nextMeeting.meeting_time %></p><% } %>
            <% if (nextMeeting.location) { %><p><%= nextMeeting.location %></p><% } %>
            <span class="badge badge--<%= nextMeeting.meeting_type %>"><%= nextMeeting.meeting_type %></span>
            <a href="/director/meetings/<%= nextMeeting.id %>/agenda" class="btn btn--outline btn--xs" style="margin-left:0.5rem">Agenda</a>
          </div>
        </div>
      <% } else { %>
        <p class="text-muted">No upcoming meetings scheduled.</p>
      <% } %>
    </div>
  </div>

  <!-- Open Polls -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Polls Awaiting Your Vote</h2>
      <a href="/director/polls" class="btn btn--outline btn--sm">All polls</a>
    </div>
    <div class="card__body">
      <% if (openPolls.length === 0) { %>
        <p class="text-muted">You've voted on all open polls.</p>
      <% } else { %>
        <% openPolls.forEach(p => { %>
          <div style="padding:0.5rem 0;border-bottom:1px solid #eee">
            <a href="/director/polls" style="font-weight:600"><%= p.question %></a>
            <div class="text-muted" style="font-size:0.8rem">By <%= p.created_by_name %> &middot; <%= p.response_count %> responses so far</div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Open Votes -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Open Votes</h2>
      <a href="/director/votes" class="btn btn--outline btn--sm">View all</a>
    </div>
    <div class="card__body">
      <% if (openVotes.length === 0) { %>
        <p class="text-muted">No open votes at this time.</p>
      <% } else { %>
        <% openVotes.slice(0, 3).forEach(v => { %>
          <div class="director-vote-item">
            <div class="director-vote-item__title"><%= v.motion_title %></div>
            <div class="director-vote-item__meta">
              <span class="badge badge--<%= v.motion_type %>"><%= v.motion_type %></span>
              <span class="text-muted"><%= v.votes_for %>F / <%= v.votes_against %>A / <%= v.votes_abstain %>Ab</span>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Recent Documents -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Recent Documents</h2>
      <a href="/director/documents" class="btn btn--outline btn--sm">View all</a>
    </div>
    <div class="card__body">
      <% if (recentDocs.length === 0) { %>
        <p class="text-muted">No documents uploaded yet.</p>
      <% } else { %>
        <% recentDocs.forEach(d => { %>
          <div class="director-doc-item">
            <div class="director-doc-item__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div class="director-doc-item__info">
              <a href="/director/documents/<%= d.id %>/download"><%= d.title %></a>
              <span class="text-muted"><%= d.uploaded_by_name %> &middot; <%= new Date(d.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
            </div>
            <span class="badge badge--<%= d.category %>"><%= d.category %></span>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Recent Activity</h2>
    </div>
    <div class="card__body">
      <% if (typeof recentActivity === 'undefined' || recentActivity.length === 0) { %>
        <p class="text-muted">No recent activity logged.</p>
      <% } else { %>
        <% recentActivity.forEach(a => { %>
          <div style="padding:0.4rem 0;border-bottom:1px solid #eee;font-size:0.85rem">
            <strong><%= a.user_name %></strong>
            <span style="color:#555"><%= a.action %></span>
            <% if (a.entity_type) { %><span class="badge" style="background:#eee;color:#555;font-size:0.65rem"><%= a.entity_type %></span><% } %>
            <% if (a.entity_label) { %><span style="color:#333"><%= a.entity_label %></span><% } %>
            <div class="text-muted" style="font-size:0.75rem"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>
</div>

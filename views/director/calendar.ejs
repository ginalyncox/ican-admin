<%
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const daysInMonth = new Date(year, month, 0).getDate();
  const firstDayOfWeek = new Date(year, month - 1, 1).getDay();
  const prevMonth = month === 1 ? 12 : month - 1;
  const prevYear = month === 1 ? year - 1 : year;
  const nextMonth = month === 12 ? 1 : month + 1;
  const nextYear = month === 12 ? year + 1 : year;
  const today = new Date();
  const todayStr = today.getFullYear() + '-' + String(today.getMonth()+1).padStart(2,'0') + '-' + String(today.getDate()).padStart(2,'0');
  const todayMonth = today.getMonth() + 1;
  const todayYear = today.getFullYear();

  // Index events by day
  const eventsByDay = {};
  meetings.forEach(m => {
    const day = parseInt(m.meeting_date.split('-')[2]);
    if (!eventsByDay[day]) eventsByDay[day] = [];
    eventsByDay[day].push({ type: 'meeting', label: m.title, id: m.id, time: m.meeting_time });
  });
  votes.forEach(v => {
    const day = parseInt(v.created_at.split('-')[2]);
    if (!eventsByDay[day]) eventsByDay[day] = [];
    eventsByDay[day].push({ type: 'vote', label: v.motion_title, id: v.id });
  });
  if (typeof actionItems !== 'undefined') {
    actionItems.forEach(ai => {
      if (ai.due_date) {
        const day = parseInt(ai.due_date.split('-')[2]);
        if (!eventsByDay[day]) eventsByDay[day] = [];
        eventsByDay[day].push({ type: 'task', label: ai.title, id: ai.id, priority: ai.priority });
      }
    });
  }
  if (typeof polls !== 'undefined') {
    polls.forEach(p => {
      const day = parseInt(p.created_at.split('-')[2]);
      if (!eventsByDay[day]) eventsByDay[day] = [];
      eventsByDay[day].push({ type: 'poll', label: p.question, id: p.id });
    });
  }
  if (typeof events !== 'undefined') {
    events.forEach(e => {
      const day = parseInt(e.event_date.split('-')[2]);
      if (!eventsByDay[day]) eventsByDay[day] = [];
      eventsByDay[day].push({ type: 'event', label: e.title, id: e.id, time: e.event_time });
    });
  }
  if (coiReminder) {
    if (!eventsByDay[31]) eventsByDay[31] = [];
    eventsByDay[31].push({ type: 'coi', label: 'COI Filing Due' });
  }
%>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
  <h1 class="page-title">Board Calendar</h1>
  <div style="display: flex; align-items: center; gap: 0.75rem;">
    <a href="/director/calendar?month=<%= prevMonth %>&year=<%= prevYear %>" class="btn btn--outline btn--sm">&larr;</a>
    <% if (month !== todayMonth || year !== todayYear) { %>
      <a href="/director/calendar?month=<%= todayMonth %>&year=<%= todayYear %>" class="btn btn--outline btn--sm">Today</a>
    <% } %>
    <span style="font-size: 1.1rem; font-weight: 600;"><%= monthNames[month-1] %> <%= year %></span>
    <a href="/director/calendar?month=<%= nextMonth %>&year=<%= nextYear %>" class="btn btn--outline btn--sm">&rarr;</a>
  </div>
</div>

<div class="board-calendar">
  <% dayNames.forEach(d => { %>
    <div class="board-calendar__header"><%= d %></div>
  <% }); %>

  <% /* Padding for days before the 1st */ %>
  <% for (let i = 0; i < firstDayOfWeek; i++) { %>
    <div class="board-calendar__day board-calendar__day--other"></div>
  <% } %>

  <% for (let d = 1; d <= daysInMonth; d++) { %>
    <%
      const dateStr = year + '-' + String(month).padStart(2,'0') + '-' + String(d).padStart(2,'0');
      const isToday = dateStr === todayStr;
      const dayEvents = eventsByDay[d] || [];
    %>
    <div class="board-calendar__day<%= isToday ? ' board-calendar__day--today' : '' %>">
      <div class="board-calendar__num"><%= d %></div>
      <% dayEvents.forEach(ev => { %>
        <% if (ev.type === 'meeting') { %>
          <a href="/director/meetings/<%= ev.id %>" class="board-calendar__event board-calendar__event--meeting" title="<%= ev.label %><%= ev.time ? ' at ' + ev.time : '' %>"><%= ev.label %></a>
        <% } else if (ev.type === 'vote') { %>
          <a href="/director/votes" class="board-calendar__event board-calendar__event--vote" title="<%= ev.label %>"><%= ev.label %></a>
        <% } else if (ev.type === 'task') { %>
          <a href="/director/tasks" class="board-calendar__event board-calendar__event--task" title="Due: <%= ev.label %>"><%= ev.label %></a>
        <% } else if (ev.type === 'poll') { %>
          <a href="/director/polls" class="board-calendar__event board-calendar__event--poll" title="Poll: <%= ev.label %>"><%= ev.label %></a>
        <% } else if (ev.type === 'event') { %>
          <a href="#" class="board-calendar__event board-calendar__event--org-event" title="<%= ev.label %>"><%= ev.label %></a>
        <% } else { %>
          <a href="/director/coi" class="board-calendar__event board-calendar__event--coi" title="<%= ev.label %>"><%= ev.label %></a>
        <% } %>
      <% }); %>
    </div>
  <% } %>

  <% /* Padding for remaining days */ %>
  <% const totalCells = firstDayOfWeek + daysInMonth; %>
  <% const remainder = totalCells % 7; %>
  <% if (remainder > 0) { for (let i = 0; i < (7 - remainder); i++) { %>
    <div class="board-calendar__day board-calendar__day--other"></div>
  <% } } %>
</div>

<div style="margin-top: 1rem; display: flex; gap: 1rem; flex-wrap: wrap; font-size: 0.78rem; color: var(--color-muted);">
  <div style="display: flex; align-items: center; gap: 0.35rem;">
    <span style="width: 12px; height: 12px; border-radius: 2px; background: var(--primary);"></span> Meeting
  </div>
  <div style="display: flex; align-items: center; gap: 0.35rem;">
    <span style="width: 12px; height: 12px; border-radius: 2px; background: #6366f1;"></span> Open Vote
  </div>
  <div style="display: flex; align-items: center; gap: 0.35rem;">
    <span style="width: 12px; height: 12px; border-radius: 2px; background: #c0392b;"></span> Action Item Due
  </div>
  <div style="display: flex; align-items: center; gap: 0.35rem;">
    <span style="width: 12px; height: 12px; border-radius: 2px; background: #8b5cf6;"></span> Poll
  </div>
  <div style="display: flex; align-items: center; gap: 0.35rem;">
    <span style="width: 12px; height: 12px; border-radius: 2px; background: #0891b2;"></span> Event
  </div>
  <div style="display: flex; align-items: center; gap: 0.35rem;">
    <span style="width: 12px; height: 12px; border-radius: 2px; background: #f59e0b;"></span> COI Deadline
  </div>
</div>

<style>
  .board-calendar__event--task { background: #fef2f2; color: #c0392b; border-left: 2px solid #c0392b; }
  .board-calendar__event--poll { background: #f5f3ff; color: #8b5cf6; border-left: 2px solid #8b5cf6; }
  .board-calendar__event--org-event { background: #ecfeff; color: #0891b2; border-left: 2px solid #0891b2; }
</style>

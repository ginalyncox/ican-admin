<div class="page-header">
  <div>
    <h1 class="page-title">Edit Announcement</h1>
    <p class="page-subtitle"><%= announcement.title %></p>
  </div>
  <a href="/director/announcements" class="btn btn--outline">Back to Announcements</a>
</div>

<div class="card">
  <div class="card__body">
    <form method="POST" action="/director/announcements/<%= announcement.id %>/edit">
      <div class="form-group">
        <label class="form-label">Title *</label>
        <input type="text" name="title" class="form-control" required value="<%= announcement.title %>">
      </div>
      <div class="form-group">
        <label class="form-label">Message *</label>
        <textarea name="body" class="form-control" rows="6" required><%= announcement.body %></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Priority</label>
          <select name="priority" class="form-control">
            <% ['normal','important','urgent'].forEach(p => { %>
              <option value="<%= p %>" <%= announcement.priority === p ? 'selected' : '' %>><%= p.charAt(0).toUpperCase() + p.slice(1) %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group" style="display:flex;align-items:center;gap:0.5rem;padding-top:1.5rem">
          <input type="checkbox" name="pinned" id="pinned" value="1" <%= announcement.pinned ? 'checked' : '' %>>
          <label for="pinned" class="form-label" style="margin:0">Pin to top</label>
        </div>
      </div>
      <div class="form-actions">
        <a href="/director/announcements" class="btn btn--outline">Cancel</a>
        <button type="submit" class="btn btn--primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

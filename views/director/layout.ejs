<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — ICAN Board Portal</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg viewBox='0 0 32 32' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z' fill='%232D6A3F'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/admin/static/admin.css">
</head>
<body class="director-body">
  <div class="director-layout">
    <header class="director-header">
      <div class="director-header__brand">
        <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
          <path d="M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z" fill="#2D6A3F" opacity="0.9"/>
          <path d="M16 8 L16 24" stroke="#F5F3ED" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 14 L12 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M16 14 L20 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <span>ICAN Board Portal</span>
      </div>
      <nav class="director-nav">
        <a href="/director" class="director-nav__link <%= path === '/director' || path === '/director/' ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Dashboard
        </a>
        <a href="/director/meetings" class="director-nav__link <%= path.startsWith('/director/meetings') ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Meetings
        </a>
        <a href="/director/votes" class="director-nav__link <%= path.startsWith('/director/votes') ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          Votes
        </a>
        <a href="/director/documents" class="director-nav__link <%= path.startsWith('/director/documents') ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Documents
        </a>
        <a href="/director/coi" class="director-nav__link <%= path.startsWith('/director/coi') ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          COI
        </a>
        <a href="/director/calendar" class="director-nav__link <%= path.startsWith('/director/calendar') ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><circle cx="12" cy="15" r="1"/></svg>
          Calendar
        </a>
        <a href="/director/financials" class="director-nav__link <%= path.startsWith('/director/financials') ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          Financials
        </a>
        <a href="/director/roster" class="director-nav__link <%= path.startsWith('/director/roster') ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Roster
        </a>
        <a href="/director/profile" class="director-nav__link <%= path.startsWith('/director/profile') ? 'director-nav__link--active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile
        </a>
      </nav>
      <div class="director-header__user">
        <% if (typeof hasVolunteerAccess !== 'undefined' && hasVolunteerAccess) { %>
          <a href="/member/login" class="director-nav__link director-nav__link--portal" title="Switch to Volunteer Portal">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>
            Volunteer Portal
          </a>
        <% } %>
        <span class="director-header__name"><%= director.name %></span>
        <% if (director.officerTitle) { %><span class="director-header__role"><%= director.officerTitle %></span><% } %>
        <a href="/director/logout" class="btn btn--outline btn--xs">Sign out</a>
      </div>
    </header>

    <main class="director-main">
      <% const dFlash = typeof directorFlash !== 'undefined' ? directorFlash : null; %>
      <% if (dFlash) { %>
        <div class="alert alert--<%= dFlash.type %>">
          <%= dFlash.message %>
          <button class="alert__close" onclick="this.parentElement.remove()">&times;</button>
        </div>
      <% } %>
      <%- body %>
    </main>

    <footer class="director-footer">
      <p>Iowa Cannabis Action Network &middot; Board of Directors Portal</p>
    </footer>
  </div>
</body>
</html>

<div class="page-header">
  <h1 class="page-title">Board Meetings</h1>
  <button class="btn btn--primary" onclick="document.getElementById('newMeetingModal').style.display='flex'">Schedule Meeting</button>
</div>

<!-- Upcoming Meetings -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card__header">
    <h2 class="card__title">Upcoming</h2>
  </div>
  <div class="card__body">
    <% if (upcoming.length === 0) { %>
      <p class="text-muted">No upcoming meetings.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Title</th>
            <th>Time</th>
            <th>Location</th>
            <th>Type</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% upcoming.forEach(m => { %>
            <tr>
              <td><%= new Date(m.meeting_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
              <td><strong><%= m.title %></strong></td>
              <td><%= m.meeting_time || '—' %></td>
              <td><%= m.location || '—' %></td>
              <td><span class="badge badge--<%= m.meeting_type %>"><%= m.meeting_type %></span></td>
              <td class="table__actions"><a href="/director/meetings/<%= m.id %>" class="btn btn--outline btn--sm">Details</a></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<!-- Past Meetings -->
<div class="card">
  <div class="card__header">
    <h2 class="card__title">Past Meetings</h2>
  </div>
  <div class="card__body">
    <% if (past.length === 0) { %>
      <p class="text-muted">No past meetings.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Title</th>
            <th>Type</th>
            <th>Status</th>
            <th>Minutes</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% past.forEach(m => { %>
            <tr>
              <td><%= new Date(m.meeting_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
              <td><%= m.title %></td>
              <td><span class="badge badge--<%= m.meeting_type %>"><%= m.meeting_type %></span></td>
              <td><span class="badge badge--<%= m.status === 'completed' ? 'garden' : 'general' %>"><%= m.status %></span></td>
              <td>
                <% if (m.minutes_approved) { %>
                  <span class="badge badge--garden">Approved</span>
                <% } else if (m.minutes) { %>
                  <span class="badge badge--legislative">Draft</span>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
              <td class="table__actions"><a href="/director/meetings/<%= m.id %>" class="btn btn--outline btn--sm">View</a></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<!-- New Meeting Modal -->
<div id="newMeetingModal" class="modal-overlay" style="display:none;">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Schedule Meeting</h2>
      <button class="modal-close" onclick="this.closest('.modal-overlay').style.display='none'">&times;</button>
    </div>
    <form method="POST" action="/director/meetings">
      <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" class="form-control" required placeholder="e.g., Regular Board Meeting — April 2026">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="meeting_date">Date</label>
          <input type="date" id="meeting_date" name="meeting_date" class="form-control" required>
        </div>
        <div class="form-group">
          <label for="meeting_time">Time</label>
          <input type="text" id="meeting_time" name="meeting_time" class="form-control" placeholder="6:00 PM">
        </div>
      </div>
      <div class="form-group">
        <label for="location">Location</label>
        <input type="text" id="location" name="location" class="form-control" placeholder="Meeting location or video link">
      </div>
      <div class="form-group">
        <label for="meeting_type">Type</label>
        <select id="meeting_type" name="meeting_type" class="form-control">
          <option value="regular">Regular</option>
          <option value="special">Special</option>
          <option value="annual">Annual</option>
          <option value="committee">Committee</option>
          <option value="emergency">Emergency</option>
        </select>
      </div>
      <div class="form-group">
        <label for="agenda">Agenda (optional)</label>
        <textarea id="agenda" name="agenda" class="form-control" rows="5" placeholder="Meeting agenda items..."></textarea>
      </div>
      <div class="form-actions">
        <button type="button" class="btn btn--outline" onclick="this.closest('.modal-overlay').style.display='none'">Cancel</button>
        <button type="submit" class="btn btn--primary">Schedule Meeting</button>
      </div>
    </form>
  </div>
</div>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg viewBox='0 0 32 32' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z' fill='%232D6A3F'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/admin/static/admin.css">
  <style>
    .unified-login-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #F5F3ED;
      padding: 1rem;
    }
    .unified-login-card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      padding: 2rem;
      width: 100%;
      max-width: 440px;
    }
    .unified-login-header {
      text-align: center;
      margin-bottom: 1.5rem;
    }
    .unified-login-header svg {
      margin-bottom: 0.75rem;
    }
    .unified-login-header h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #1E2418;
      margin: 0;
    }
    .unified-login-header p {
      font-size: 0.85rem;
      color: #5E6B52;
      margin: 0.25rem 0 0;
    }
    .unified-login-form .form-field {
      margin-bottom: 1rem;
    }
    .unified-login-form label {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: #1E2418;
      margin-bottom: 0.3rem;
    }
    .unified-login-form input {
      width: 100%;
      padding: 0.6rem 0.75rem;
      border: 1px solid #D4D1C7;
      border-radius: 6px;
      font-size: 0.9rem;
      background: #FAFAF8;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .unified-login-form input:focus {
      outline: none;
      border-color: #2D6A3F;
      box-shadow: 0 0 0 3px rgba(45, 106, 63, 0.1);
    }
    .unified-login-submit {
      width: 100%;
      padding: 0.65rem;
      background: #2D6A3F;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 0.25rem;
    }
    .unified-login-submit:hover {
      background: #245633;
    }
    .unified-login-footer {
      text-align: center;
      margin-top: 1.25rem;
      font-size: 0.78rem;
      color: #5E6B52;
    }
    .unified-login-footer a {
      color: #2D6A3F;
      text-decoration: none;
    }
    .unified-login-footer a:hover {
      text-decoration: underline;
    }
    .alert--error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
      padding: 0.6rem 0.75rem;
      border-radius: 6px;
      font-size: 0.82rem;
      margin-bottom: 1rem;
    }
    .name-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .register-note {
      font-size: 0.75rem;
      color: #8A9478;
      text-align: center;
      margin-top: 1rem;
      line-height: 1.5;
    }
  </style>
</head>
<body class="unified-login-page">
  <div class="unified-login-card">
    <div class="unified-login-header">
      <svg viewBox="0 0 32 32" fill="none" width="44" height="44">
        <path d="M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z" fill="#2D6A3F" opacity="0.9"/>
        <path d="M16 8 L16 24" stroke="#F5F3ED" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M16 14 L12 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M16 14 L20 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M16 18 L11 15.5" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M16 18 L21 15.5" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <h1>Create Your Account</h1>
      <p>Join ICAN as a volunteer</p>
    </div>

    <% if (error) { %>
      <div class="alert--error"><%= error %></div>
    <% } %>

    <form method="POST" action="/register" class="unified-login-form">
      <div class="name-row">
        <div class="form-field">
          <label for="first_name">First Name</label>
          <input type="text" id="first_name" name="first_name" required placeholder="First name">
        </div>
        <div class="form-field">
          <label for="last_name">Last Name</label>
          <input type="text" id="last_name" name="last_name" required placeholder="Last name">
        </div>
      </div>
      <div class="form-field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com">
      </div>
      <div class="form-field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="At least 8 characters" minlength="8">
      </div>
      <div class="form-field">
        <label for="confirm_password">Confirm Password</label>
        <input type="password" id="confirm_password" name="confirm_password" required placeholder="Re-enter your password">
      </div>
      <button type="submit" class="unified-login-submit">Create Account</button>
    </form>

    <p class="register-note">By creating an account, you agree to ICAN's policies. You'll complete onboarding after registration.</p>

    <div class="unified-login-footer">
      Already have an account? <a href="/login">Sign in</a>
    </div>
  </div>
</body>
</html>

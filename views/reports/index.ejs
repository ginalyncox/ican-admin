<div class="page-header">
  <h1 class="page-header__title">Reports</h1>
  <p class="page-header__subtitle">Generate certified reports and data exports</p>
</div>

<div class="stats-grid stats-grid--4" style="margin-bottom: 1.5rem;">
  <div class="stat-card">
    <div class="stat-card__label">Hours This Year</div>
    <div class="stat-card__value"><%= Number(totalHoursThisYear).toFixed(1) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Hours All Time</div>
    <div class="stat-card__value"><%= Number(totalHoursAllTime).toFixed(1) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Active Volunteers</div>
    <div class="stat-card__value"><%= activeVolunteers %></div>
  </div>
</div>

<div class="portal-grid">
  <!-- Certified Hours Report -->
  <div class="card">
    <div class="card__header" style="border-left: 3px solid var(--primary);">
      <h2 class="card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Volunteer Hours Report
      </h2>
    </div>
    <div class="card__body">
      <p style="font-size: 0.9rem; color: var(--color-muted); margin-bottom: 1rem;">
        Generate annual or year-to-date reports of all volunteer hours. Export as CSV or view a certified printable report with ICAN organizational seal.
      </p>
      <form method="GET" action="/admin/reports/hours" style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: flex-end;">
        <div class="form-field" style="margin-bottom: 0; flex: 0 0 auto;">
          <label class="form-label" style="font-size: 0.8rem;">Year</label>
          <select name="year" class="form-select form-select--sm">
            <% years.forEach(y => { %>
              <option value="<%= y %>" <%= y === currentYear ? 'selected' : '' %>><%= y === currentYear ? y + ' (YTD)' : y %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-field" style="margin-bottom: 0; flex: 0 0 auto;">
          <label class="form-label" style="font-size: 0.8rem;">Program</label>
          <select name="program" class="form-select form-select--sm">
            <option value="">All Programs</option>
            <option value="victory_garden">Victory Garden</option>
            <option value="legislative">Legislative</option>
            <option value="outreach">Outreach</option>
            <option value="fundraising">Fundraising</option>
            <option value="communications">Communications</option>
            <option value="membership">Membership</option>
          </select>
        </div>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          <button type="submit" class="btn btn--primary btn--sm">View Report</button>
          <button type="submit" name="format" value="certified" class="btn btn--outline btn--sm" formtarget="_blank">Certified PDF</button>
          <button type="submit" name="format" value="csv" class="btn btn--ghost btn--sm">Export CSV</button>
          <button type="submit" name="format" value="summary-csv" class="btn btn--ghost btn--sm">Summary CSV</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Quick Individual Letter -->
  <div class="card">
    <div class="card__header" style="border-left: 3px solid var(--accent);">
      <h2 class="card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Individual Volunteer Letter
      </h2>
    </div>
    <div class="card__body">
      <p style="font-size: 0.9rem; color: var(--color-muted); margin-bottom: 1rem;">
        Generate a certified hours letter for a specific volunteer. Useful for community service verification, grant applications, or volunteer recognition.
      </p>
      <p style="font-size: 0.85rem; color: var(--color-muted);">
        Open any volunteer's profile and use the "Certified Hours Letter" button, or go to the
        <a href="/admin/reports/hours">Hours Report</a> and click a volunteer's name.
      </p>
    </div>
  </div>
</div>

<div class="page-header">
  <h1 class="page-header__title">Settings</h1>
  <p class="page-header__subtitle">Manage your account and team</p>
</div>

<div class="dashboard-grid">
  <!-- Change Password -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Change Password</h2>
    </div>
    <div class="card__body">
      <form method="POST" action="/admin/settings/password">
        <div class="form-field">
          <label for="current_password">Current Password</label>
          <input type="password" id="current_password" name="current_password" class="form-input" required>
        </div>
        <div class="form-field">
          <label for="new_password">New Password</label>
          <input type="password" id="new_password" name="new_password" class="form-input" required minlength="8">
          <small class="text-muted">At least 8 characters</small>
        </div>
        <div class="form-field">
          <label for="confirm_password">Confirm New Password</label>
          <input type="password" id="confirm_password" name="confirm_password" class="form-input" required>
        </div>
        <button type="submit" class="btn btn--primary">Update Password</button>
      </form>
    </div>
  </div>

  <!-- Edit Profile -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Your Profile</h2>
    </div>
    <div class="card__body">
      <form method="POST" action="/admin/settings/profile">
        <div class="form-field">
          <label for="name">Display Name</label>
          <input type="text" id="name" name="name" class="form-input" value="<%= currentUser.name %>" required>
        </div>
        <div class="form-field">
          <label>Email</label>
          <input type="email" class="form-input" value="<%= currentUser.email %>" disabled>
          <small class="text-muted">Contact an admin to change email</small>
        </div>
        <div class="form-field">
          <label>Role</label>
          <input type="text" class="form-input" value="<%= currentUser.role %>" disabled style="text-transform: capitalize">
        </div>
        <button type="submit" class="btn btn--primary">Save Profile</button>
      </form>
    </div>
  </div>
</div>

<% if (user.role === 'admin') { %>
<!-- Team Management -->
<div class="card" style="margin-top: 2rem">
  <div class="card__header">
    <h2 class="card__title">Team Members</h2>
    <button class="btn btn--primary btn--sm" onclick="document.getElementById('addUserModal').classList.add('modal--open')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Staff
    </button>
  </div>
  <div class="card__body">
    <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><strong><%= u.name %></strong> <% if (u.id === currentUser.id) { %><span class="badge badge--info">You</span><% } %></td>
            <td class="text-muted"><%= u.email %></td>
            <td>
              <% if (u.id !== currentUser.id) { %>
                <form method="POST" action="/admin/settings/users/<%= u.id %>/role" style="display:inline">
                  <select name="role" class="form-select" style="width: auto; padding: 0.2rem 0.5rem; font-size: 0.8rem" onchange="this.form.submit()">
                    <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    <option value="editor" <%= u.role === 'editor' ? 'selected' : '' %>>Editor</option>
                    <option value="viewer" <%= u.role === 'viewer' ? 'selected' : '' %>>Viewer</option>
                  </select>
                </form>
              <% } else { %>
                <span class="badge badge--active"><%= u.role %></span>
              <% } %>
            </td>
            <td class="text-muted text-sm"><%= new Date(u.created_at).toLocaleDateString() %></td>
            <td class="table__actions">
              <% if (u.id !== currentUser.id) { %>
                <form method="POST" action="/admin/settings/users/<%= u.id %>/delete" onsubmit="return confirm('Remove this team member?')">
                  <button type="submit" class="btn btn--danger btn--sm">Remove</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </div>
</div>

<!-- Add User Modal -->
<div class="modal" id="addUserModal">
  <div class="modal__backdrop" onclick="this.parentElement.classList.remove('modal--open')"></div>
  <div class="modal__content">
    <div class="modal__header">
      <h3 class="modal__title">Add Staff Member</h3>
      <button class="modal__close" onclick="this.closest('.modal').classList.remove('modal--open')">&times;</button>
    </div>
    <div class="modal__body">
      <form method="POST" action="/admin/settings/users">
        <div class="form-field">
          <label for="new_name">Name</label>
          <input type="text" id="new_name" name="name" class="form-input" required>
        </div>
        <div class="form-field">
          <label for="new_email">Email</label>
          <input type="email" id="new_email" name="email" class="form-input" required>
        </div>
        <div class="form-field">
          <label for="new_pw">Password</label>
          <input type="password" id="new_pw" name="password" class="form-input" required minlength="8">
        </div>
        <div class="form-field">
          <label for="new_role">Role</label>
          <select id="new_role" name="role" class="form-select">
            <option value="editor">Editor &mdash; Can create and edit content</option>
            <option value="viewer">Viewer &mdash; Read-only access</option>
            <option value="admin">Admin &mdash; Full access</option>
          </select>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn--primary">Add Member</button>
          <button type="button" class="btn btn--ghost" onclick="this.closest('.modal').classList.remove('modal--open')">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

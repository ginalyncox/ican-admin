<div class="page-header">
  <h1 class="page-header__title">Donations</h1>
  <p class="page-header__subtitle">Track all donations — Stripe and manual</p>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-card__icon" style="background: rgba(45, 106, 63, 0.1); color: #2D6A3F;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value">$<%= (totalAll / 100).toFixed(2) %></span>
      <span class="stat-card__label">Total Raised (All Time)</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-card__icon" style="background: rgba(184, 134, 43, 0.1); color: #B8862B;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value">$<%= (totalMonth / 100).toFixed(2) %></span>
      <span class="stat-card__label">This Month</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-card__icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value">$<%= (totalYear / 100).toFixed(2) %></span>
      <span class="stat-card__label">This Year</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-card__icon stat-card__icon--subscribers">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= donationCount %></span>
      <span class="stat-card__label">Total Donations</span>
    </div>
  </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem; margin-top: 1.5rem;">
  <!-- Recent Donations -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Recent Donations</h2>
    </div>
    <div class="card__body">
      <% if (recent.length === 0) { %>
        <p class="empty-state">No donations recorded yet.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Donor</th>
              <th>Amount</th>
              <th>Type</th>
              <th>Source</th>
            </tr>
          </thead>
          <tbody>
            <% recent.forEach(d => { %>
              <tr>
                <td class="text-muted"><%= new Date(d.created_at).toLocaleDateString() %></td>
                <td>
                  <% if (d.donor_name) { %><strong><%= d.donor_name %></strong><% } %>
                  <% if (d.donor_email) { %><br><span class="text-muted" style="font-size: 0.78rem;"><%= d.donor_email %></span><% } %>
                  <% if (!d.donor_name && !d.donor_email) { %><span class="text-muted">Anonymous</span><% } %>
                </td>
                <td style="font-weight: 600; color: #2D6A3F;">$<%= (d.amount_cents / 100).toFixed(2) %></td>
                <td><span class="badge"><%= d.donation_type %></span></td>
                <td>
                  <% if (d.stripe_payment_id) { %>
                    <span class="badge badge--legislative">Stripe</span>
                  <% } else { %>
                    <span class="badge badge--meeting">Manual</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <!-- Manual Entry Form -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Record Donation</h2>
    </div>
    <div class="card__body">
      <p style="font-size: 0.82rem; color: var(--color-muted); margin-bottom: 1rem;">Record cash, check, or other offline donations.</p>
      <form method="POST" action="/admin/donations">
        <div class="form-group" style="margin-bottom: 0.75rem;">
          <label class="form-label">Donor Name</label>
          <input type="text" name="donor_name" class="form-control" placeholder="Optional">
        </div>
        <div class="form-group" style="margin-bottom: 0.75rem;">
          <label class="form-label">Donor Email</label>
          <input type="email" name="donor_email" class="form-control" placeholder="Optional">
        </div>
        <div class="form-group" style="margin-bottom: 0.75rem;">
          <label class="form-label">Amount ($) *</label>
          <input type="number" name="amount" class="form-control" step="0.01" min="0.01" required placeholder="25.00">
        </div>
        <div class="form-group" style="margin-bottom: 0.75rem;">
          <label class="form-label">Type</label>
          <select name="donation_type" class="form-control">
            <option value="one-time">One-time</option>
            <option value="recurring">Recurring</option>
            <option value="in-kind">In-kind</option>
            <option value="cash">Cash</option>
            <option value="check">Check</option>
          </select>
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
          <label class="form-label">Notes</label>
          <textarea name="notes" class="form-control" rows="2" placeholder="Optional notes"></textarea>
        </div>
        <button type="submit" class="btn btn--primary" style="width: 100%;">Record Donation</button>
      </form>
    </div>
  </div>
</div>

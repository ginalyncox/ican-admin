<div class="page-header">
  <h1 class="page-header__title">Dashboard</h1>
  <p class="page-header__subtitle">Welcome back, <%= user.name %></p>
</div>

<!-- Organization Overview -->
<div class="stats-grid">
  <a href="/admin/garden/gardeners" class="stat-card stat-card--link">
    <div class="stat-card__icon stat-card__icon--subscribers">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= stats.activeVolunteers %></span>
      <span class="stat-card__label">Active Volunteers</span>
    </div>
  </a>

  <% if (stats.pendingApplications > 0) { %>
  <a href="/admin/garden/applications" class="stat-card stat-card--attention stat-card--link">
    <div class="stat-card__icon stat-card__icon--pending">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= stats.pendingApplications %></span>
      <span class="stat-card__label">Pending Applications</span>
    </div>
  </a>
  <% } %>

  <div class="stat-card">
    <div class="stat-card__icon stat-card__icon--submissions">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= stats.unreadSubmissions %></span>
      <span class="stat-card__label">Unread Submissions</span>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-card__icon stat-card__icon--subscribers">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= stats.totalSubscribers %></span>
      <span class="stat-card__label">Subscribers</span>
    </div>
  </div>

  <% if (stats.pendingVerifications > 0) { %>
  <a href="/admin/garden/verify" class="stat-card stat-card--attention stat-card--link">
    <div class="stat-card__icon stat-card__icon--pending">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= stats.pendingVerifications %></span>
      <span class="stat-card__label">Pending Verifications</span>
    </div>
  </a>
  <% } %>
</div>

<!-- Program Enrollment Overview -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card__header">
    <h2 class="card__title">Program Enrollment</h2>
    <a href="/admin/garden/applications" class="card__link">Review Applications</a>
  </div>
  <div class="card__body">
    <% const programInfo = [
      { key: 'victory_garden', label: 'Victory Garden', color: '#2D6A3F', icon: '🌱' },
      { key: 'legislative', label: 'Legislative Action', color: '#6366f1', icon: '🏛️' },
      { key: 'outreach', label: 'Community Outreach', color: '#f59e0b', icon: '📢' },
      { key: 'fundraising', label: 'Fundraising', color: '#10b981', icon: '💰' },
      { key: 'communications', label: 'Communications', color: '#8b5cf6', icon: '✉️' },
      { key: 'membership', label: 'Membership', color: '#ec4899', icon: '👥' }
    ]; %>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;">
      <% programInfo.forEach(p => { %>
        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; border-radius: var(--radius); border: 1px solid var(--color-border);">
          <div style="width: 36px; height: 36px; border-radius: 8px; background: <%= p.color %>15; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0;"><%= p.icon %></div>
          <div>
            <div style="font-weight: 600; font-size: 0.85rem;"><%= p.label %></div>
            <div style="font-size: 0.8rem; color: var(--color-muted);"><%= (stats.programCounts[p.key] || 0) %> volunteer<%= (stats.programCounts[p.key] || 0) !== 1 ? 's' : '' %></div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- Portal Management -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card__header">
    <h2 class="card__title">Portal Management</h2>
  </div>
  <div class="card__body">
    <div class="portal-grid">
      <a href="/admin/board" class="portal-card">
        <div class="portal-card__icon" style="background: rgba(45, 106, 63, 0.1); color: var(--primary);">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="portal-card__info">
          <h3>Director Portal</h3>
          <p><%= stats.activeBoardMembers %> board member<%= stats.activeBoardMembers !== 1 ? 's' : '' %></p>
          <% if (stats.openBoardVotes > 0) { %><span class="badge badge--legislative"><%= stats.openBoardVotes %> open vote<%= stats.openBoardVotes !== 1 ? 's' : '' %></span><% } %>
          <% if (stats.upcomingBoardMeetings > 0) { %><span class="badge badge--meeting"><%= stats.upcomingBoardMeetings %> upcoming meeting<%= stats.upcomingBoardMeetings !== 1 ? 's' : '' %></span><% } %>
        </div>
        <span class="portal-card__action">Manage &rarr;</span>
      </a>

      <a href="/admin/garden/members" class="portal-card">
        <div class="portal-card__icon" style="background: rgba(184, 134, 43, 0.1); color: var(--accent);">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>
        </div>
        <div class="portal-card__info">
          <h3>Volunteer Portal</h3>
          <p><%= stats.memberPortalUsers %> portal account<%= stats.memberPortalUsers !== 1 ? 's' : '' %></p>
          <p class="text-muted" style="font-size:0.8rem;"><%= stats.activeVolunteers %> active volunteers</p>
        </div>
        <span class="portal-card__action">Manage &rarr;</span>
      </a>

      <a href="/admin" class="portal-card portal-card--current">
        <div class="portal-card__icon" style="background: rgba(30, 36, 24, 0.08); color: var(--text);">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09"/></svg>
        </div>
        <div class="portal-card__info">
          <h3>Staff Admin</h3>
          <p>You are here</p>
          <p class="text-muted" style="font-size:0.8rem;">Manages all portals & content</p>
        </div>
        <span class="portal-card__action" style="opacity:0.4;">Current</span>
      </a>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card__header">
    <h2 class="card__title">Quick Actions</h2>
  </div>
  <div class="card__body">
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
      <a href="/admin/garden/gardeners/new" class="btn btn--primary btn--sm">Add Volunteer</a>
      <a href="/admin/garden/members/new" class="btn btn--outline btn--sm">Create Member Login</a>
      <a href="/admin/messages/compose" class="btn btn--outline btn--sm">Send Message</a>
      <a href="/admin/newsletter/compose" class="btn btn--outline btn--sm">Compose Newsletter</a>
      <a href="/admin/events/new" class="btn btn--outline btn--sm">Create Event</a>
      <a href="/admin/posts/new" class="btn btn--outline btn--sm">Write Post</a>
    </div>
  </div>
</div>

<div class="dashboard-grid">
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Recent Posts</h2>
      <a href="/admin/posts" class="card__link">View all</a>
    </div>
    <div class="card__body">
      <% if (recentPosts.length === 0) { %>
        <p class="empty-state">No posts yet. <a href="/admin/posts/new">Create your first post</a></p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% recentPosts.forEach(post => { %>
              <tr>
                <td><a href="/admin/posts/<%= post.id %>/edit"><%= post.title %></a></td>
                <td><span class="badge badge--<%= post.status %>"><%= post.status %></span></td>
                <td class="text-muted"><%= new Date(post.updated_at).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Recent Submissions</h2>
      <a href="/admin/submissions" class="card__link">View all</a>
    </div>
    <div class="card__body">
      <% if (recentSubmissions.length === 0) { %>
        <p class="empty-state">No form submissions yet.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% recentSubmissions.forEach(sub => { %>
              <tr>
                <td><span class="badge badge--<%= sub.form_type %>"><%= sub.form_type %></span></td>
                <td><%= sub.read ? 'Read' : '<strong>New</strong>' %></td>
                <td class="text-muted"><%= new Date(sub.created_at).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

<!-- Activity Feed -->
<div class="card" style="margin-top: 1.5rem;">
  <div class="card__header">
    <h2 class="card__title">Recent Activity</h2>
  </div>
  <div class="card__body">
    <% if (recentActivity.length === 0) { %>
      <p class="empty-state">No activity recorded yet. Actions will appear here as you manage volunteers, applications, messages, and more.</p>
    <% } else { %>
      <div class="activity-feed">
        <% recentActivity.forEach(a => { %>
          <%
            const iconMap = {
              volunteer: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>',
              application: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>',
              message: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
              member_account: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',
              board: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
              event: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
              settings: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9"/></svg>'
            };
            const icon = iconMap[a.entity_type] || iconMap.settings;
            const ago = (() => {
              const diff = Date.now() - new Date(a.created_at + 'Z').getTime();
              const mins = Math.floor(diff / 60000);
              if (mins < 1) return 'just now';
              if (mins < 60) return mins + 'm ago';
              const hrs = Math.floor(mins / 60);
              if (hrs < 24) return hrs + 'h ago';
              const days = Math.floor(hrs / 24);
              if (days < 7) return days + 'd ago';
              return new Date(a.created_at).toLocaleDateString();
            })();
          %>
          <div class="activity-item">
            <div class="activity-item__icon"><%- icon %></div>
            <div class="activity-item__content">
              <span class="activity-item__text">
                <strong><%= a.user_name || 'System' %></strong> <%= a.action %>
                <% if (a.entity_label) { %><strong><%= a.entity_label %></strong><% } %>
              </span>
              <% if (a.details) { %><span class="activity-item__details"><%= a.details %></span><% } %>
            </div>
            <span class="activity-item__time"><%= ago %></span>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

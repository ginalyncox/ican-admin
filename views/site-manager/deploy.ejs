<div class="page-header">
  <div class="page-header__row">
    <div>
      <h1 class="page-header__title">Deploy Website</h1>
      <p class="page-header__subtitle">Push updated content to GitHub Pages</p>
    </div>
    <div class="page-header__actions">
      <a href="/admin/site" class="btn btn--outline btn--sm">&larr; Site Manager</a>
    </div>
  </div>
</div>

<div class="dashboard-grid">
  <!-- Deploy Action -->
  <div class="card">
    <div class="card__header"><h2 class="card__title">Deploy to GitHub Pages</h2></div>
    <div class="card__body" style="text-align: center; padding: 2rem;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.5" style="margin-bottom: 1rem;">
        <path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4z"/>
      </svg>
      <p style="font-size: 0.9rem; margin-bottom: 0.5rem;">This will update the public website with the latest settings and content.</p>
      <p style="font-size: 0.8rem; color: var(--color-muted); margin-bottom: 1.5rem;">
        Target: <strong>ginalyncox/IowaCannabisAction</strong> (GitHub Pages)
      </p>

      <% if (lastDeploy) { %>
        <p style="font-size: 0.8rem; color: var(--color-muted); margin-bottom: 1rem;">
          Last deploy: <strong><%= new Date(lastDeploy).toLocaleString() %></strong>
          <% if (lastDeployBy) { %> by <%= lastDeployBy %><% } %>
        </p>
      <% } %>

      <form method="POST" action="/admin/site/deploy">
        <button type="submit" class="btn btn--primary" style="padding: 0.75rem 2rem; font-size: 1rem;" onclick="return confirm('Queue a deploy to GitHub Pages?')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -3px; margin-right: 0.35rem;"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4z"/></svg>
          Deploy Now
        </button>
      </form>
    </div>
  </div>

  <!-- What Will Change -->
  <div class="card">
    <div class="card__header"><h2 class="card__title">What Gets Deployed</h2></div>
    <div class="card__body">
      <ul style="font-size: 0.85rem; line-height: 1.8; padding-left: 1.2rem; color: var(--color-muted);">
        <li>Organization name, email, and contact info</li>
        <li>Mission statement and tagline</li>
        <li>Social media links</li>
        <li>Web3Forms API key for contact form</li>
        <li>Board member profiles (from Board of Directors)</li>
        <li>Upcoming events (public events only)</li>
      </ul>
      <div style="margin-top: 1rem; padding: 0.75rem; background: rgba(245,158,11,0.08); border-radius: var(--radius); border: 1px solid rgba(245,158,11,0.2);">
        <p style="font-size: 0.8rem; color: #b45309; margin: 0;">
          <strong>Note:</strong> Deploy records the intent. The actual push to GitHub requires additional authorization and will be triggered separately.
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Deploy History -->
<div class="card" style="margin-top: 1.5rem;">
  <div class="card__header"><h2 class="card__title">Deploy History</h2></div>
  <div class="card__body">
    <% if (deployHistory.length === 0) { %>
      <p class="text-muted">No deploys recorded yet.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr><th>Date</th><th>Deployed By</th><th>Status</th></tr>
        </thead>
        <tbody>
          <% deployHistory.forEach(d => { %>
            <tr>
              <td><%= new Date(d.at).toLocaleString() %></td>
              <td><%= d.by %></td>
              <td>
                <span style="display: inline-block; padding: 0.15rem 0.5rem; border-radius: 999px; font-size: 0.72rem; font-weight: 600; background: <%= d.status === 'pending' ? '#f59e0b18' : d.status === 'success' ? '#2D6A3F18' : '#ef444418' %>; color: <%= d.status === 'pending' ? '#f59e0b' : d.status === 'success' ? '#2D6A3F' : '#ef4444' %>;">
                  <%= d.status %>
                </span>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

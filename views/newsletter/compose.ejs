<div class="page-header">
  <div class="page-header__row">
    <div>
      <h1 class="page-header__title">Compose Newsletter</h1>
      <p class="page-header__subtitle">Will be sent to <%= activeCount %> active subscriber<%= activeCount !== 1 ? 's' : '' %></p>
    </div>
    <a href="/admin/newsletter" class="btn btn--ghost">Back</a>
  </div>
</div>

<% if (typeof brevoConfigured !== 'undefined' && brevoConfigured) { %>
<div style="padding: 0.75rem 1rem; background: var(--success-light); border: 1px solid var(--primary); border-radius: 6px; margin-bottom: 1.25rem; font-size: 0.85rem; color: var(--primary);">
  Email delivery is active via Brevo. Newsletters will be sent directly to subscriber inboxes.
</div>
<% } else { %>
<div style="padding: 0.75rem 1rem; background: var(--warning-light); border: 1px solid var(--warning); border-radius: 6px; margin-bottom: 1.25rem; font-size: 0.85rem; color: var(--text);">
  Email delivery is not configured. Add <code>BREVO_API_KEY</code> to your environment variables to send real emails. <a href="https://www.brevo.com/" target="_blank">Get a free Brevo account</a>
</div>
<% } %>

<div class="card">
  <div class="card__body">
    <form method="POST" action="/admin/newsletter/preview" id="newsletterForm">
      <div class="form-field">
        <label for="subject">Subject Line</label>
        <input type="text" id="subject" name="subject" class="form-input form-input--lg" placeholder="e.g. ICAN March Update: Victory Garden Launch" required>
      </div>

      <div class="form-field">
        <label for="body">Message Body</label>
        <textarea id="body" name="body" class="form-input" rows="16" placeholder="Write your newsletter content here...

Paragraphs are separated by blank lines.
Use line breaks for structure.

Links and formatting will be wrapped in a branded ICAN email template." required></textarea>
      </div>

      <div class="form-actions" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <button type="submit" class="btn btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          Preview
        </button>
        <% if (typeof brevoConfigured !== 'undefined' && brevoConfigured) { %>
        <button type="button" class="btn btn--outline" onclick="sendTest()">
          Send Test to Me
        </button>
        <% } %>
        <a href="/admin/newsletter" class="btn btn--ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

<% if (typeof brevoConfigured !== 'undefined' && brevoConfigured) { %>
<!-- Hidden form for sending test email -->
<form method="POST" action="/admin/newsletter/test" id="testForm" style="display: none;">
  <input type="hidden" name="subject" id="testSubject">
  <input type="hidden" name="body" id="testBody">
</form>
<script>
function sendTest() {
  var subj = document.getElementById('subject').value;
  var body = document.getElementById('body').value;
  if (!subj || !body) { alert('Please enter a subject and body first.'); return; }
  document.getElementById('testSubject').value = subj;
  document.getElementById('testBody').value = body;
  document.getElementById('testForm').submit();
}
</script>
<% } %>

<div class="page-header">
  <h1 class="page-header__title">Preview Newsletter</h1>
  <p class="page-header__subtitle">Review before recording the send</p>
</div>

<div class="card">
  <div class="card__header">
    <h2 class="card__title"><%= subject %></h2>
    <span class="badge badge--info"><%= activeCount %> recipient<%= activeCount !== 1 ? 's' : '' %></span>
  </div>
  <div class="card__body">
    <div style="white-space: pre-wrap; line-height: 1.7; font-size: 0.95rem; max-width: 600px"><%= body %></div>
  </div>
</div>

<div style="margin-top: 1.5rem; display: flex; gap: 0.75rem">
  <form method="POST" action="/admin/newsletter/send">
    <input type="hidden" name="subject" value="<%= subject %>">
    <input type="hidden" name="body" value="<%= body %>">
    <button type="submit" class="btn btn--primary btn--lg" onclick="return confirm('Record this newsletter send for ' + <%= activeCount %> + ' subscribers?')">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4z"/></svg>
      Record Send
    </button>
  </form>
  <form method="GET" action="/admin/newsletter/compose">
    <button type="submit" class="btn btn--ghost btn--lg">Edit</button>
  </form>
</div>

<div class="page-header">
  <h1 class="page-header__title">Pages</h1>
</div>

<div class="card">
  <div class="card__body">
    <% if (pages.length === 0) { %>
      <p class="empty-state">No pages found. Run the seed script to create default pages.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Page</th>
            <th>Slug</th>
            <th>Last Updated</th>
            <th>Updated By</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% pages.forEach(page => { %>
            <tr>
              <td><strong><%= page.title %></strong></td>
              <td class="text-muted">/<%= page.slug %></td>
              <td class="text-muted"><%= new Date(page.updated_at).toLocaleDateString() %></td>
              <td class="text-muted"><%= page.editor_name || '—' %></td>
              <td>
                <a href="/admin/pages/<%= page.id %>/edit" class="btn btn--sm btn--ghost" title="Edit">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  Edit
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

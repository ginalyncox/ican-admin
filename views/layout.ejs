<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — ICAN Admin</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg viewBox='0 0 32 32' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z' fill='%232D6A3F'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/admin/static/admin.css">
  <%- typeof head !== 'undefined' ? head : '' %>
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__header">
        <a href="/admin" class="sidebar__logo">
          <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
            <path d="M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z" fill="#2D6A3F" opacity="0.9"/>
            <path d="M16 8 L16 24" stroke="#F5F3ED" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M16 14 L12 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M16 14 L20 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M16 18 L11 15.5" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M16 18 L21 15.5" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <span>ICAN Admin</span>
        </a>
      </div>

      <nav class="sidebar__nav">
        <a href="/admin" class="sidebar__link <%= path === '/admin' || path === '/admin/' ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Dashboard
        </a>
        <a href="/admin/analytics" class="sidebar__link <%= path.startsWith('/admin/analytics') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          Analytics
        </a>
        <a href="/admin/posts" class="sidebar__link <%= path.startsWith('/admin/posts') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Posts
        </a>
        <a href="/admin/submissions" class="sidebar__link <%= path.startsWith('/admin/submissions') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Submissions
        </a>
        <a href="/admin/subscribers" class="sidebar__link <%= path.startsWith('/admin/subscribers') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Subscribers
        </a>
        <a href="/admin/directory" class="sidebar__link <%= path.startsWith('/admin/directory') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Directory
        </a>
        <a href="/admin/pages" class="sidebar__link <%= path.startsWith('/admin/pages') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Pages
        </a>
        <a href="/admin/newsletter" class="sidebar__link <%= path.startsWith('/admin/newsletter') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4z"/></svg>
          Newsletter
        </a>
        <a href="/admin/events" class="sidebar__link <%= path.startsWith('/admin/events') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Events
        </a>

        <div class="sidebar__divider"></div>

        <a href="/admin/garden" class="sidebar__link <%= path.startsWith('/admin/garden') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/><path d="M8 18c0-2.2 1.8-4 4-4s4 1.8 4 4"/></svg>
          Victory Garden
        </a>
        <a href="/admin/board" class="sidebar__link <%= path.startsWith('/admin/board') ? 'sidebar__link--active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Board of Directors
        </a>
      </nav>

      <div class="sidebar__footer">
        <div class="sidebar__user">
          <div class="sidebar__user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
          <div class="sidebar__user-info">
            <span class="sidebar__user-name"><%= user.name %></span>
            <span class="sidebar__user-role"><%= user.role %></span>
          </div>
        </div>
        <a href="/admin/settings" class="sidebar__logout" style="margin-bottom: 0.25rem; display: flex; align-items: center; gap: 0.5rem;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Settings
        </a>
        <a href="/admin/logout" class="sidebar__logout">Sign out</a>
      </div>
    </aside>

    <!-- Mobile header -->
    <header class="topbar">
      <button class="topbar__toggle" onclick="document.getElementById('sidebar').classList.toggle('sidebar--open')" aria-label="Toggle menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
      <span class="topbar__title"><%= title %></span>
      <a href="/admin/logout" class="topbar__logout">Sign out</a>
    </header>

    <!-- Main content -->
    <main class="main-content">
      <% if (flash) { %>
        <div class="alert alert--<%= flash.type %>">
          <%= flash.message %>
          <button class="alert__close" onclick="this.parentElement.remove()">&times;</button>
        </div>
      <% } %>
      <%- body %>
    </main>
  </div>

  <script>
    // Close sidebar on mobile when clicking outside
    document.addEventListener('click', (e) => {
      const sidebar = document.getElementById('sidebar');
      const toggle = document.querySelector('.topbar__toggle');
      if (sidebar.classList.contains('sidebar--open') && !sidebar.contains(e.target) && !toggle.contains(e.target)) {
        sidebar.classList.remove('sidebar--open');
      }
    });
  </script>
  <%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>

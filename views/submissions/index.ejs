<div class="page-header">
  <h1 class="page-header__title">Form Submissions</h1>
</div>

<div class="filters">
  <form method="GET" action="/admin/submissions" class="filters__form">
    <select name="type" class="form-select" onchange="this.form.submit()">
      <option value="">All Types</option>
      <option value="contact" <%= filter === 'contact' ? 'selected' : '' %>>Contact</option>
      <option value="newsletter" <%= filter === 'newsletter' ? 'selected' : '' %>>Newsletter</option>
      <option value="volunteer" <%= filter === 'volunteer' ? 'selected' : '' %>>Volunteer</option>
      <option value="board_application" <%= filter === 'board_application' ? 'selected' : '' %>>Board Application</option>
    </select>
  </form>
</div>

<div class="card">
  <div class="card__body">
    <% if (submissions.length === 0) { %>
      <p class="empty-state">No submissions found.</p>
    <% } else { %>
      <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th>Type</th>
            <th>Preview</th>
            <th>Status</th>
            <th>Received</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% submissions.forEach(sub => { %>
            <% const data = JSON.parse(sub.data); %>
            <tr class="<%= !sub.read ? 'table__row--unread' : '' %>">
              <td><span class="badge badge--<%= sub.form_type %>"><%= sub.form_type %></span></td>
              <td>
                <strong><%= data.name || data.email || 'Anonymous' %></strong>
                <% if (data.subject) { %>
                  <br><span class="text-muted text-sm"><%= data.subject %></span>
                <% } %>
                <% if (data.message) { %>
                  <br><span class="text-muted text-sm"><%= data.message.substring(0, 80) %><%= data.message.length > 80 ? '...' : '' %></span>
                <% } %>
              </td>
              <td>
                <% if (!sub.read) { %>
                  <span class="badge badge--new">New</span>
                <% } else { %>
                  <span class="text-muted">Read</span>
                <% } %>
              </td>
              <td class="text-muted"><%= new Date(sub.created_at).toLocaleDateString() %></td>
              <td class="actions-cell">
                <a href="/admin/submissions/<%= sub.id %>" class="btn btn--sm btn--ghost" title="View details">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </a>
                <% if (sub.form_type === 'volunteer' && data.email) { %>
                  <form method="POST" action="/admin/submissions/<%= sub.id %>/create-member" style="display:inline" onsubmit="return confirm('Create a member portal account for <%= (data.first_name || data.name || data.email).replace(/'/g, '') %>?');">
                    <button type="submit" class="btn btn--sm btn--primary" title="Create member portal account">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                    </button>
                  </form>
                <% } %>
                <% if (sub.form_type === 'board_application' && data.email) { %>
                  <form method="POST" action="/admin/submissions/<%= sub.id %>/create-director" style="display:inline" onsubmit="return confirm('Create a Director Portal account for <%= (data.first_name || data.name || data.email).replace(/'/g, '') %>? This will add them to the Board of Directors.');">
                    <button type="submit" class="btn btn--sm btn--accent" title="Create director account" style="background: var(--color-accent); color: #fff;">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </button>
                  </form>
                <% } %>
                <form method="POST" action="/admin/submissions/<%= sub.id %>/toggle-read<%= filter ? `?type=${filter}` : '' %>" style="display:inline">
                  <button type="submit" class="btn btn--sm btn--ghost" title="<%= sub.read ? 'Mark unread' : 'Mark read' %>">
                    <% if (sub.read) { %>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <% } else { %>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22,6 12,13 2,6"/><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/></svg>
                    <% } %>
                  </button>
                </form>
                <form method="POST" action="/admin/submissions/<%= sub.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this submission?')">
                  <button type="submit" class="btn btn--sm btn--ghost" style="color:var(--danger);" title="Delete">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
    <% } %>
  </div>
</div>

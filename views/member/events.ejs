<div class="page-header">
  <div class="page-header__row">
    <div>
      <h1 class="page-header__title">Events</h1>
      <p class="page-header__subtitle">ICAN community events and activities</p>
    </div>
    <div class="page-header__actions">
      <a href="/member/events?filter=upcoming" class="btn btn--<%= filter === 'upcoming' ? 'primary' : 'outline' %> btn--sm">Upcoming</a>
      <a href="/member/events?filter=past" class="btn btn--<%= filter === 'past' ? 'primary' : 'outline' %> btn--sm">Past</a>
    </div>
  </div>
</div>

<% if (events.length === 0) { %>
  <div class="card">
    <div class="card__body" style="text-align: center; padding: 2rem;">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-muted)" stroke-width="1.5" style="margin-bottom: 0.75rem;">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      <p style="font-size: 1rem; color: var(--color-muted); margin: 0;">No <%= filter %> events at this time.</p>
    </div>
  </div>
<% } else { %>
  <div class="portal-grid">
    <%
    const typeIcons = {
      general: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
      meeting: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
      garden: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>',
      legislative: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/></svg>',
      fundraiser: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
      social: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>'
    };
    const typeColors = { general: '#666', meeting: '#6366f1', garden: '#2D6A3F', legislative: '#6366f1', fundraiser: '#10b981', social: '#ec4899' };
    %>
    <% events.forEach(e => { %>
      <div class="card">
        <div class="card__header" style="border-left: 3px solid <%= typeColors[e.event_type] || '#666' %>;">
          <h2 class="card__title" style="display: flex; align-items: center; gap: 0.5rem;">
            <%- typeIcons[e.event_type] || typeIcons.general %>
            <%= e.title %>
          </h2>
        </div>
        <div class="card__body">
          <div style="display: flex; gap: 1rem; margin-bottom: 0.75rem;">
            <div style="min-width: 52px; text-align: center; background: var(--primary); color: #fff; border-radius: 8px; padding: 6px 8px;">
              <div style="font-size: 1.3rem; font-weight: 700; line-height: 1.1;"><%= new Date(e.event_date + 'T00:00:00').toLocaleDateString('en-US', { day: 'numeric' }) %></div>
              <div style="font-size: 0.7rem; text-transform: uppercase;"><%= new Date(e.event_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short' }) %></div>
              <div style="font-size: 0.65rem; opacity: 0.8;"><%= new Date(e.event_date + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'short' }) %></div>
            </div>
            <div>
              <% if (e.event_time) { %>
                <p style="font-size: 0.9rem; margin-bottom: 0.25rem;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -2px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <%= e.event_time %><%= e.end_time ? ' \u2013 ' + e.end_time : '' %>
                </p>
              <% } %>
              <% if (e.location) { %>
                <p style="font-size: 0.9rem; margin-bottom: 0.25rem; color: var(--color-muted);">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -2px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <%= e.location %>
                </p>
              <% } %>
              <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                <span class="badge" style="font-size: 0.7rem;"><%= e.event_type %></span>
                <% if (e.goingCount > 0) { %>
                  <span style="font-size: 0.75rem; color: var(--color-muted);"><%= e.goingCount %> going</span>
                <% } %>
              </div>
            </div>
          </div>
          <% if (e.description) { %>
            <p style="font-size: 0.85rem; color: var(--color-muted); margin: 0 0 0.75rem 0; line-height: 1.5;"><%= e.description %></p>
          <% } %>

          <% if (filter !== 'past') { %>
            <div style="display: flex; gap: 0.5rem; align-items: center; border-top: 1px solid var(--color-border); padding-top: 0.75rem;">
              <% if (e.myRsvp === 'going') { %>
                <span class="badge badge--success" style="font-size: 0.75rem;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align: -1px;"><polyline points="20 6 9 17 4 12"/></svg>
                  Going
                </span>
                <form method="POST" action="/member/events/<%= e.id %>/rsvp" style="margin: 0;">
                  <input type="hidden" name="status" value="cancel">
                  <button type="submit" class="btn btn--ghost btn--sm" style="font-size: 0.75rem;">Cancel RSVP</button>
                </form>
              <% } else if (e.myRsvp === 'interested') { %>
                <span class="badge" style="background: #f59e0b; color: #fff; font-size: 0.75rem;">Interested</span>
                <form method="POST" action="/member/events/<%= e.id %>/rsvp" style="margin: 0;">
                  <input type="hidden" name="status" value="going">
                  <button type="submit" class="btn btn--primary btn--sm" style="font-size: 0.75rem;">Going</button>
                </form>
                <form method="POST" action="/member/events/<%= e.id %>/rsvp" style="margin: 0;">
                  <input type="hidden" name="status" value="cancel">
                  <button type="submit" class="btn btn--ghost btn--sm" style="font-size: 0.75rem;">Cancel</button>
                </form>
              <% } else { %>
                <form method="POST" action="/member/events/<%= e.id %>/rsvp" style="margin: 0;">
                  <input type="hidden" name="status" value="going">
                  <button type="submit" class="btn btn--primary btn--sm" style="font-size: 0.75rem;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -1px;"><polyline points="20 6 9 17 4 12"/></svg>
                    Going
                  </button>
                </form>
                <form method="POST" action="/member/events/<%= e.id %>/rsvp" style="margin: 0;">
                  <input type="hidden" name="status" value="interested">
                  <button type="submit" class="btn btn--outline btn--sm" style="font-size: 0.75rem;">Interested</button>
                </form>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<div class="page-header">
  <div class="page-header__row">
    <div>
      <h1 class="page-header__title"><%= message.subject %></h1>
      <p class="page-header__subtitle"><%= new Date(message.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></p>
    </div>
    <div class="page-header__actions">
      <a href="/member/mailbox" class="btn btn--outline btn--sm">&larr; Mailbox</a>
    </div>
  </div>
</div>

<div class="card">
  <div class="card__body">
    <p style="margin-bottom: 0.75rem;">
      <span class="badge"><%= message.message_type %></span>
    </p>
    <div style="white-space: pre-wrap; font-size: 0.9rem; line-height: 1.6;"><%= message.body %></div>
  </div>
</div>

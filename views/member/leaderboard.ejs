<div class="page-header">
  <h1 class="page-header__title">Leaderboard</h1>
</div>

<div class="dashboard-grid">
  <div class="card">
    <div class="card__header"><h2 class="card__title">Harvest Leaders (lbs)</h2></div>
    <div class="card__body">
      <table class="table">
        <thead><tr><th>Rank</th><th>Gardener</th><th>Site</th><th>Lbs</th></tr></thead>
        <tbody>
          <% harvestLeaders.forEach((g, i) => { %>
            <tr class="<%= g.id === myId ? 'leaderboard-me' : '' %>">
              <td><span class="rank-badge rank-badge--<%= i+1 %>"><%= i+1 %></span></td>
              <td><%= g.first_name %> <%= g.last_name %><%= g.id === myId ? ' (You)' : '' %></td>
              <td><%= g.site_name || '—' %></td>
              <td><strong><%= Number(g.total_lbs).toFixed(1) %></strong></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card__header"><h2 class="card__title">Volunteer Hours Leaders</h2></div>
    <div class="card__body">
      <table class="table">
        <thead><tr><th>Rank</th><th>Gardener</th><th>Site</th><th>Hours</th></tr></thead>
        <tbody>
          <% hoursLeaders.forEach((g, i) => { %>
            <tr class="<%= g.id === myId ? 'leaderboard-me' : '' %>">
              <td><span class="rank-badge rank-badge--<%= i+1 %>"><%= i+1 %></span></td>
              <td><%= g.first_name %> <%= g.last_name %><%= g.id === myId ? ' (You)' : '' %></td>
              <td><%= g.site_name || '—' %></td>
              <td><strong><%= Number(g.total_hrs).toFixed(1) %></strong></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

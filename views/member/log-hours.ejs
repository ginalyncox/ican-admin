<div class="page-header">
  <div class="page-header__row">
    <h1 class="page-header__title">Log Volunteer Hours</h1>
    <a href="/member" class="btn btn--ghost">Back to Dashboard</a>
  </div>
</div>

<div class="card" style="max-width: 600px">
  <div class="card__body">
    <form method="POST" action="/member/log-hours">
      <% if (seasons.length > 0) { %>
      <div class="form-field">
        <label for="season_id">Season</label>
        <select id="season_id" name="season_id" class="form-select">
          <% seasons.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.name %> (<%= s.year %>)</option>
          <% }) %>
        </select>
      </div>
      <% } %>

      <div class="form-row">
        <div class="form-field">
          <label for="work_date">Date</label>
          <input type="date" id="work_date" name="work_date" class="form-input" value="<%= new Date().toISOString().split('T')[0] %>" required>
        </div>
        <div class="form-field">
          <label for="hours">Hours</label>
          <input type="number" id="hours" name="hours" class="form-input" step="0.25" min="0" required placeholder="0.0">
        </div>
      </div>

      <div class="form-field">
        <label for="activity">Activity</label>
        <input type="text" id="activity" name="activity" class="form-input" placeholder="e.g. Weeding, planting, watering">
      </div>

      <div class="form-field">
        <label for="notes">Notes (optional)</label>
        <textarea id="notes" name="notes" class="form-input" rows="3" placeholder="Any additional details..."></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Log Hours</button>
        <a href="/member" class="btn btn--ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

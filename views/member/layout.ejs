<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — ICAN Volunteer Portal</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg viewBox='0 0 32 32' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z' fill='%232D6A3F'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/admin/static/admin.css">
</head>
<body class="member-body">
  <div class="member-layout">
    <header class="member-header">
      <div class="member-header__brand">
        <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
          <path d="M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z" fill="#2D6A3F" opacity="0.9"/>
          <path d="M16 8 L16 24" stroke="#F5F3ED" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 14 L12 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M16 14 L20 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <span>ICAN Volunteer Portal</span>
      </div>
      <nav class="member-nav">
        <a href="/member" class="member-nav__link <%= path === '/member' || path === '/member/' ? 'member-nav__link--active' : '' %>">Dashboard</a>
        <a href="/member/programs" class="member-nav__link <%= path === '/member/programs' ? 'member-nav__link--active' : '' %>">Programs</a>
        <a href="/member/my-hours" class="member-nav__link <%= path === '/member/my-hours' ? 'member-nav__link--active' : '' %>">My Hours</a>
        <a href="/member/events" class="member-nav__link <%= path === '/member/events' ? 'member-nav__link--active' : '' %>">Events</a>
        <% if (typeof memberPrograms !== 'undefined' && memberPrograms && memberPrograms.includes('victory_garden')) { %>
          <a href="/member/leaderboard" class="member-nav__link <%= path === '/member/leaderboard' ? 'member-nav__link--active' : '' %>">Leaderboard</a>
          <a href="/member/awards" class="member-nav__link <%= path === '/member/awards' ? 'member-nav__link--active' : '' %>">Awards</a>
        <% } %>
        <a href="/member/mailbox" class="member-nav__link <%= path === '/member/mailbox' || (path && path.startsWith('/member/mailbox/')) ? 'member-nav__link--active' : '' %>">Mailbox</a>
        <a href="/member/resources" class="member-nav__link <%= path === '/member/resources' ? 'member-nav__link--active' : '' %>">Resources</a>
        <a href="/member/profile" class="member-nav__link <%= path === '/member/profile' ? 'member-nav__link--active' : '' %>">Profile</a>
      </nav>

      <!-- Notifications Bell -->
      <div class="notif-bell" onclick="document.getElementById('notifDropdown').classList.toggle('open')" style="margin-right: 0.75rem;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F5F3ED" stroke-width="2" stroke-linecap="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <% const notifTotal = (typeof unreadMessages !== 'undefined' ? unreadMessages : 0); %>
        <% if (notifTotal > 0) { %>
          <span class="notif-bell__count"><%= notifTotal > 9 ? '9+' : notifTotal %></span>
        <% } %>
        <div class="notif-dropdown" id="notifDropdown" onclick="event.stopPropagation()">
          <div class="notif-dropdown__header">Notifications</div>
          <% if (notifTotal === 0 && (!recentAppUpdates || recentAppUpdates.length === 0)) { %>
            <div class="notif-dropdown__empty">You're all caught up.</div>
          <% } else { %>
            <% if (typeof unreadMessages !== 'undefined' && unreadMessages > 0) { %>
              <a href="/member/mailbox" class="notif-dropdown__item notif-dropdown__item--unread" style="display: block; text-decoration: none; color: inherit;">
                <strong><%= unreadMessages %></strong> unread message<%= unreadMessages !== 1 ? 's' : '' %> in your mailbox
              </a>
            <% } %>
            <%
              const appProgramLabels = { victory_garden: 'Victory Garden', legislative: 'Legislative Action', outreach: 'Community Outreach', fundraising: 'Fundraising', communications: 'Communications', membership: 'Membership' };
            %>
            <% if (typeof recentAppUpdates !== 'undefined') { recentAppUpdates.forEach(app => { %>
              <div class="notif-dropdown__item">
                Your application for <strong><%= appProgramLabels[app.program] || app.program %></strong> was
                <span style="color: <%= app.status === 'approved' ? '#2D6A3F' : '#ef4444' %>; font-weight: 600;"><%= app.status %></span>
              </div>
            <% }); } %>
          <% } %>
        </div>
      </div>
      <div class="member-header__user">
        <% if (typeof hasDirectorAccess !== 'undefined' && hasDirectorAccess) { %>
          <a href="/director/login" class="member-nav__link member-nav__link--portal" title="Switch to Director Portal">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Board Portal
          </a>
        <% } %>
        <span><%= member.name %></span>
        <a href="/member/logout" class="btn btn--outline btn--xs">Sign out</a>
      </div>
    </header>

    <main class="member-main">
      <% const mFlash = typeof memberFlash !== 'undefined' ? memberFlash : null; %>
      <% if (mFlash) { %>
        <div class="alert alert--<%= mFlash.type %>">
          <%= mFlash.message %>
          <button class="alert__close" onclick="this.parentElement.remove()">&times;</button>
        </div>
      <% } %>
      <%- body %>
    </main>

    <footer class="member-footer">
      <p>Iowa Cannabis Action Network &middot; Volunteer Portal</p>
    </footer>
  </div>
</body>
</html>

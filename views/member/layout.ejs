<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — ICAN Volunteer Portal</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg viewBox='0 0 32 32' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z' fill='%232D6A3F'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/admin/static/admin.css">
</head>
<body class="member-body">
  <div class="member-layout">
    <header class="member-header">
      <button class="mobile-menu-toggle" onclick="toggleMobileNav()" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="member-header__brand">
        <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
          <path d="M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z" fill="#2D6A3F" opacity="0.9"/>
          <path d="M16 8 L16 24" stroke="#F5F3ED" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 14 L12 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M16 14 L20 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <span>ICAN Volunteer Portal</span>
      </div>
      <nav class="member-nav">
        <a href="/member" class="member-nav__link <%= path === '/member' || path === '/member/' ? 'member-nav__link--active' : '' %>">Dashboard</a>
        <a href="/member/programs" class="member-nav__link <%= path === '/member/programs' ? 'member-nav__link--active' : '' %>">Programs</a>
        <a href="/member/my-hours" class="member-nav__link <%= path === '/member/my-hours' ? 'member-nav__link--active' : '' %>">My Hours</a>
        <% if (typeof memberPrograms !== 'undefined' && memberPrograms && memberPrograms.includes('victory_garden')) { %>
          <a href="/member/my-harvests" class="member-nav__link <%= path === '/member/my-harvests' ? 'member-nav__link--active' : '' %>">My Harvests</a>
        <% } %>
        <a href="/member/events" class="member-nav__link <%= path === '/member/events' ? 'member-nav__link--active' : '' %>">Events</a>
        <% if (typeof memberPrograms !== 'undefined' && memberPrograms && memberPrograms.includes('victory_garden')) { %>
          <a href="/member/leaderboard" class="member-nav__link <%= path === '/member/leaderboard' ? 'member-nav__link--active' : '' %>">Leaderboard</a>
          <a href="/member/awards" class="member-nav__link <%= path === '/member/awards' ? 'member-nav__link--active' : '' %>">Awards</a>
        <% } %>
        <a href="/member/mailbox" class="member-nav__link <%= path === '/member/mailbox' || (path && path.startsWith('/member/mailbox/')) ? 'member-nav__link--active' : '' %>">Mailbox</a>
        <a href="/member/documents" class="member-nav__link <%= path === '/member/documents' ? 'member-nav__link--active' : '' %>">Documents</a>
        <a href="/member/resources" class="member-nav__link <%= path === '/member/resources' ? 'member-nav__link--active' : '' %>">Resources</a>
        <a href="/member/profile" class="member-nav__link <%= path === '/member/profile' ? 'member-nav__link--active' : '' %>">Profile</a>
      </nav>

      <!-- Notifications Bell -->
      <div class="notif-bell" onclick="document.getElementById('notifDropdown').classList.toggle('open')" style="margin-right: 0.75rem;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F5F3ED" stroke-width="2" stroke-linecap="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <% const notifTotal = (typeof unreadMessages !== 'undefined' ? unreadMessages : 0); %>
        <% if (notifTotal > 0) { %>
          <span class="notif-bell__count"><%= notifTotal > 9 ? '9+' : notifTotal %></span>
        <% } %>
        <div class="notif-dropdown" id="notifDropdown" onclick="event.stopPropagation()">
          <div class="notif-dropdown__header">Notifications</div>
          <% if (notifTotal === 0 && (!recentAppUpdates || recentAppUpdates.length === 0)) { %>
            <div class="notif-dropdown__empty">You're all caught up.</div>
          <% } else { %>
            <% if (typeof unreadMessages !== 'undefined' && unreadMessages > 0) { %>
              <a href="/member/mailbox" class="notif-dropdown__item notif-dropdown__item--unread" style="display: block; text-decoration: none; color: inherit;">
                <strong><%= unreadMessages %></strong> unread message<%= unreadMessages !== 1 ? 's' : '' %> in your mailbox
              </a>
            <% } %>
            <%
              const appProgramLabels = { victory_garden: 'Victory Garden', legislative: 'Legislative Action', outreach: 'Community Outreach', fundraising: 'Fundraising', communications: 'Communications', membership: 'Membership' };
            %>
            <% if (typeof recentAppUpdates !== 'undefined') { recentAppUpdates.forEach(app => { %>
              <div class="notif-dropdown__item">
                Your application for <strong><%= appProgramLabels[app.program] || app.program %></strong> was
                <span style="color: <%= app.status === 'approved' ? '#2D6A3F' : '#ef4444' %>; font-weight: 600;"><%= app.status %></span>
              </div>
            <% }); } %>
          <% } %>
        </div>
      </div>
      <button class="dark-mode-toggle" onclick="toggleDarkMode()" title="Toggle dark mode">
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
      <div class="member-header__user">
        <% if (typeof hasAdminAccess !== 'undefined' && hasAdminAccess) { %>
          <a href="/admin" class="member-nav__link member-nav__link--portal" title="Switch to Admin Console" style="font-size: 0.75rem; opacity: 0.85;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33"/></svg>
            Admin
          </a>
        <% } %>
        <% if (typeof hasDirectorAccess !== 'undefined' && hasDirectorAccess) { %>
          <a href="/director" class="member-nav__link member-nav__link--portal" title="Switch to Director Portal" style="font-size: 0.75rem; opacity: 0.85;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Board
          </a>
        <% } %>
        <span><%= member.name %></span>
        <a href="/member/logout" class="btn btn--outline btn--xs">Sign out</a>
      </div>
    </header>

    <main class="member-main">
      <% const mFlash = typeof memberFlash !== 'undefined' ? memberFlash : null; %>
      <% if (mFlash) { %>
        <div class="alert alert--<%= mFlash.type %>">
          <%= mFlash.message %>
          <button class="alert__close" onclick="this.parentElement.remove()">&times;</button>
        </div>
      <% } %>
      <%- body %>
    </main>

    <footer class="member-footer">
      <p>Iowa Cannabis Action Network &middot; Volunteer Portal</p>
    </footer>
  </div>

  <!-- Mobile Nav Drawer -->
  <div class="mobile-nav-overlay mobile-nav-overlay--member" id="mobileNavOverlay" onclick="closeMobileNav()"></div>
  <aside class="mobile-nav-drawer mobile-nav-drawer--member" id="mobileNavDrawer">
    <div class="mobile-nav-drawer__header">
      <div class="mobile-nav-drawer__brand">
        <svg viewBox="0 0 32 32" fill="none" width="24" height="24">
          <path d="M16 2 C16 2 13 8 9 12 C5 16 4 20 6 24 C8 28 12 30 16 30 C20 30 24 28 26 24 C28 20 27 16 23 12 C19 8 16 2 16 2Z" fill="#2D6A3F" opacity="0.9"/>
          <path d="M16 8 L16 24" stroke="#F5F3ED" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 14 L12 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M16 14 L20 11" stroke="#F5F3ED" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <span>Volunteer Portal</span>
      </div>
      <button class="mobile-nav-drawer__close" onclick="closeMobileNav()" aria-label="Close menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <nav class="mobile-nav-drawer__links">
      <a href="/member" class="mobile-nav-drawer__link <%= path === '/member' || path === '/member/' ? 'mobile-nav-drawer__link--active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Dashboard
      </a>
      <a href="/member/programs" class="mobile-nav-drawer__link <%= path === '/member/programs' ? 'mobile-nav-drawer__link--active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Programs
      </a>
      <a href="/member/my-hours" class="mobile-nav-drawer__link <%= path === '/member/my-hours' ? 'mobile-nav-drawer__link--active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        My Hours
      </a>
      <% if (typeof memberPrograms !== 'undefined' && memberPrograms && memberPrograms.includes('victory_garden')) { %>
        <a href="/member/my-harvests" class="mobile-nav-drawer__link <%= path === '/member/my-harvests' ? 'mobile-nav-drawer__link--active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>
          My Harvests
        </a>
      <% } %>
      <a href="/member/events" class="mobile-nav-drawer__link <%= path === '/member/events' ? 'mobile-nav-drawer__link--active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Events
      </a>
      <% if (typeof memberPrograms !== 'undefined' && memberPrograms && memberPrograms.includes('victory_garden')) { %>
        <a href="/member/leaderboard" class="mobile-nav-drawer__link <%= path === '/member/leaderboard' ? 'mobile-nav-drawer__link--active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          Leaderboard
        </a>
        <a href="/member/awards" class="mobile-nav-drawer__link <%= path === '/member/awards' ? 'mobile-nav-drawer__link--active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          Awards
        </a>
      <% } %>
      <a href="/member/mailbox" class="mobile-nav-drawer__link <%= path === '/member/mailbox' || (path && path.startsWith('/member/mailbox/')) ? 'mobile-nav-drawer__link--active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Mailbox
      </a>
      <a href="/member/resources" class="mobile-nav-drawer__link <%= path === '/member/resources' ? 'mobile-nav-drawer__link--active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Resources
      </a>
      <a href="/member/profile" class="mobile-nav-drawer__link <%= path === '/member/profile' ? 'mobile-nav-drawer__link--active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>
    </nav>
    <div class="mobile-nav-drawer__footer">
      <span><%= member.name %></span>
      <a href="/member/logout">Sign out</a>
    </div>
  </aside>

  <script>
    function toggleMobileNav() {
      var drawer = document.getElementById('mobileNavDrawer');
      var overlay = document.getElementById('mobileNavOverlay');
      drawer.classList.add('mobile-nav-drawer--open');
      overlay.classList.add('mobile-nav-overlay--open');
      document.body.style.overflow = 'hidden';
    }
    function closeMobileNav() {
      var drawer = document.getElementById('mobileNavDrawer');
      var overlay = document.getElementById('mobileNavOverlay');
      drawer.classList.remove('mobile-nav-drawer--open');
      overlay.classList.remove('mobile-nav-overlay--open');
      document.body.style.overflow = '';
    }
  </script>

<script>
// Dark mode toggle
(function() {
  const saved = localStorage.getItem('ican-theme');
  if (saved) document.documentElement.setAttribute('data-theme', saved);
  else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
    document.documentElement.setAttribute('data-theme', 'dark');
  }
})();
function toggleDarkMode() {
  const current = document.documentElement.getAttribute('data-theme');
  const next = current === 'dark' ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('ican-theme', next);
}
</script>
</body>
</html>

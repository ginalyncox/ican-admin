<div class="page-header">
  <h1 class="page-header__title">My Programs</h1>
  <p class="page-header__subtitle">Your assigned volunteer programs</p>
</div>

<% if (programs.length === 0) { %>
<div class="card">
  <div class="card__body" style="text-align: center; padding: 2rem;">
    <p style="font-size: 1.1rem; color: var(--color-muted); margin-bottom: 0.5rem;">No programs assigned yet.</p>
    <p style="font-size: 0.85rem; color: var(--color-muted);">Your coordinator will assign you to volunteer programs. Check back soon!</p>
  </div>
</div>
<% } else { %>
<div class="portal-grid" style="margin-bottom: 1.5rem;">
  <% programs.forEach(p => { %>
    <% const info = programInfo[p.program] || { label: p.program, color: 'var(--text)', description: '' }; %>
    <div class="card">
      <div class="card__header" style="border-left: 3px solid <%= info.color %>;">
        <h2 class="card__title"><%= info.label %></h2>
      </div>
      <div class="card__body">
        <p style="font-size: 0.9rem; color: var(--color-muted); margin-bottom: 0.75rem;"><%= info.description %></p>
        <p style="font-size: 0.8rem; color: var(--color-muted); margin-bottom: 0;">
          Assigned: <%= new Date(p.assigned_at).toLocaleDateString() %>
        </p>
        <% if (p.program === 'victory_garden') { %>
          <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <a href="/member/log-harvest" class="btn btn--primary btn--sm">Log Harvest</a>
            <a href="/member/log-hours" class="btn btn--outline btn--sm">Log Hours</a>
            <a href="/member/leaderboard" class="btn btn--ghost btn--sm">Leaderboard</a>
          </div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>
<% } %>

<div class="page-header">
  <h1 class="page-header__title">My Profile</h1>
  <p class="page-header__subtitle">Your information, membership, and milestones</p>
</div>

<%
const totalHrs = typeof profileStats !== 'undefined' ? profileStats.totalHrs : 0;
const totalEntries = typeof profileStats !== 'undefined' ? profileStats.totalEntries : 0;
const memberSinceDate = typeof memberSince !== 'undefined' ? memberSince : gardener.joined_date;

// Milestone thresholds
const hourMilestones = [
  { label: 'First Steps', threshold: 1, icon: '\u2B50' },
  { label: '10 Hour Club', threshold: 10, icon: '\uD83C\uDFC5' },
  { label: '25 Hour Achiever', threshold: 25, icon: '\uD83C\uDF1F' },
  { label: '50 Hour Champion', threshold: 50, icon: '\uD83D\uDD25' },
  { label: '100 Hour Legend', threshold: 100, icon: '\uD83C\uDFC6' },
  { label: '250 Hour Hero', threshold: 250, icon: '\uD83D\uDC8E' },
  { label: '500 Hour Icon', threshold: 500, icon: '\uD83D\uDC51' }
];
const earned = hourMilestones.filter(m => totalHrs >= m.threshold);
const nextMilestone = hourMilestones.find(m => totalHrs < m.threshold);
%>

<!-- Volunteer ID Card -->
<div class="card" style="margin-bottom: 1.5rem; overflow: hidden;">
  <div style="background: linear-gradient(135deg, #2D6A3F 0%, #1E4D2D 100%); color: #fff; padding: 1.5rem; display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap;">
    <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 700; flex-shrink: 0;">
      <%= gardener.first_name.charAt(0) %><%= gardener.last_name.charAt(0) %>
    </div>
    <div style="flex: 1; min-width: 200px;">
      <div style="font-size: 1.25rem; font-weight: 700;"><%= gardener.first_name %> <%= gardener.last_name %></div>
      <div style="font-size: 0.85rem; opacity: 0.85;">Active Volunteer</div>
      <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap;">
        <% programs.forEach(p => { %>
          <span style="background: rgba(255,255,255,0.2); padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.75rem;"><%= programLabels[p.program] || p.program %></span>
        <% }); %>
      </div>
    </div>
    <div style="text-align: right; font-size: 0.8rem; opacity: 0.8;">
      <div>Member since</div>
      <div style="font-weight: 600; font-size: 0.9rem;"><%= new Date(memberSinceDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></div>
      <div style="margin-top: 0.5rem;">Total Hours</div>
      <div style="font-weight: 700; font-size: 1.3rem;"><%= Number(totalHrs).toFixed(1) %></div>
    </div>
  </div>
</div>

<!-- Milestones -->
<% if (earned.length > 0 || nextMilestone) { %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
      Hour Milestones
    </h2>
  </div>
  <div class="card__body">
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.75rem;">
      <% earned.forEach(m => { %>
        <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 0.5rem 0.75rem; text-align: center; min-width: 90px;">
          <div style="font-size: 1.25rem;"><%= m.icon %></div>
          <div style="font-size: 0.75rem; font-weight: 600; color: #166534;"><%= m.label %></div>
          <div style="font-size: 0.7rem; color: #15803d;"><%= m.threshold %> hrs</div>
        </div>
      <% }); %>
      <% if (nextMilestone) { %>
        <div style="background: var(--bg); border: 2px dashed var(--color-border); border-radius: 8px; padding: 0.5rem 0.75rem; text-align: center; min-width: 90px; opacity: 0.6;">
          <div style="font-size: 1.25rem;"><%= nextMilestone.icon %></div>
          <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-muted);"><%= nextMilestone.label %></div>
          <div style="font-size: 0.7rem; color: var(--color-muted);"><%= (nextMilestone.threshold - totalHrs).toFixed(1) %> hrs to go</div>
        </div>
      <% } %>
    </div>
    <% if (nextMilestone) { %>
      <div style="background: var(--color-border); border-radius: 4px; height: 6px; overflow: hidden;">
        <div style="background: var(--primary); height: 100%; width: <%= Math.min(100, (totalHrs / nextMilestone.threshold) * 100) %>%; border-radius: 4px; transition: width 0.3s;"></div>
      </div>
      <div style="font-size: 0.8rem; color: var(--color-muted); margin-top: 0.25rem;">
        <%= Number(totalHrs).toFixed(1) %> / <%= nextMilestone.threshold %> hours toward "<%= nextMilestone.label %>"
      </div>
    <% } %>
  </div>
</div>
<% } %>

<div class="dashboard-grid">
  <!-- Contact Info -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Contact Information</h2>
    </div>
    <div class="card__body">
      <form method="POST" action="/member/profile">
        <div class="form-field">
          <label>Name</label>
          <input type="text" class="form-input" value="<%= gardener.first_name %> <%= gardener.last_name %>" disabled>
          <small class="text-muted">Contact your coordinator to change your name</small>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" class="form-input" value="<%= gardener.email || '' %>" placeholder="your@email.com">
          </div>
          <div class="form-field">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" class="form-input" value="<%= gardener.phone || '' %>" placeholder="(515) 555-0123">
          </div>
        </div>
        <div class="form-field">
          <label for="address">Street Address</label>
          <input type="text" id="address" name="address" class="form-input" value="<%= gardener.address || '' %>" placeholder="123 Main St">
        </div>
        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 1rem;">
          <div class="form-field">
            <label for="city">City</label>
            <input type="text" id="city" name="city" class="form-input" value="<%= gardener.city || '' %>">
          </div>
          <div class="form-field">
            <label for="state">State</label>
            <input type="text" id="state" name="state" class="form-input" value="<%= gardener.state || '' %>" maxlength="2">
          </div>
          <div class="form-field">
            <label for="zip">Zip</label>
            <input type="text" id="zip" name="zip" class="form-input" value="<%= gardener.zip || '' %>" maxlength="10">
          </div>
        </div>
        <div class="form-field">
          <label for="date_of_birth">Date of Birth</label>
          <input type="date" id="date_of_birth" name="date_of_birth" class="form-input" value="<%= gardener.date_of_birth || '' %>">
        </div>

        <hr style="margin: 1.25rem 0; border-color: var(--color-border);">
        <p style="font-weight: 600; margin-bottom: 0.75rem;">Emergency Contact</p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-field">
            <label for="emergency_contact_name">Name</label>
            <input type="text" id="emergency_contact_name" name="emergency_contact_name" class="form-input" value="<%= gardener.emergency_contact_name || '' %>">
          </div>
          <div class="form-field">
            <label for="emergency_contact_phone">Phone</label>
            <input type="tel" id="emergency_contact_phone" name="emergency_contact_phone" class="form-input" value="<%= gardener.emergency_contact_phone || '' %>">
          </div>
        </div>

        <hr style="margin: 1.25rem 0; border-color: var(--color-border);">
        <p style="font-weight: 600; margin-bottom: 0.75rem;">Volunteer Details</p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-field">
            <label for="tshirt_size">T-Shirt Size</label>
            <select id="tshirt_size" name="tshirt_size" class="form-input">
              <option value="">&mdash;</option>
              <option value="XS" <%= gardener.tshirt_size === 'XS' ? 'selected' : '' %>>XS</option>
              <option value="S" <%= gardener.tshirt_size === 'S' ? 'selected' : '' %>>S</option>
              <option value="M" <%= gardener.tshirt_size === 'M' ? 'selected' : '' %>>M</option>
              <option value="L" <%= gardener.tshirt_size === 'L' ? 'selected' : '' %>>L</option>
              <option value="XL" <%= gardener.tshirt_size === 'XL' ? 'selected' : '' %>>XL</option>
              <option value="2XL" <%= gardener.tshirt_size === '2XL' ? 'selected' : '' %>>2XL</option>
              <option value="3XL" <%= gardener.tshirt_size === '3XL' ? 'selected' : '' %>>3XL</option>
            </select>
          </div>
          <div class="form-field">
            <label for="availability">Availability</label>
            <select id="availability" name="availability" class="form-input">
              <option value="">&mdash;</option>
              <option value="weekdays" <%= gardener.availability === 'weekdays' ? 'selected' : '' %>>Weekdays</option>
              <option value="weekends" <%= gardener.availability === 'weekends' ? 'selected' : '' %>>Weekends</option>
              <option value="evenings" <%= gardener.availability === 'evenings' ? 'selected' : '' %>>Evenings</option>
              <option value="flexible" <%= gardener.availability === 'flexible' ? 'selected' : '' %>>Flexible</option>
            </select>
          </div>
        </div>
        <div class="form-field">
          <label for="skills">Skills or Interests</label>
          <textarea id="skills" name="skills" class="form-input" rows="2"><%= gardener.skills || '' %></textarea>
        </div>

        <div class="form-field">
          <label>Login Email</label>
          <input type="text" class="form-input" value="<%= memberEmail %>" disabled>
          <small class="text-muted">This is separate from your contact email</small>
        </div>
        <button type="submit" class="btn btn--primary">Save Changes</button>
      </form>
    </div>
  </div>

  <!-- Change Password -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Change Password</h2>
    </div>
    <div class="card__body">
      <form method="POST" action="/member/change-password">
        <div class="form-field">
          <label for="current_password">Current Password</label>
          <input type="password" id="current_password" name="current_password" class="form-input" required>
        </div>
        <div class="form-field">
          <label for="new_password">New Password</label>
          <input type="password" id="new_password" name="new_password" class="form-input" required minlength="8">
          <small class="text-muted">At least 8 characters</small>
        </div>
        <div class="form-field">
          <label for="confirm_password">Confirm New Password</label>
          <input type="password" id="confirm_password" name="confirm_password" class="form-input" required>
        </div>
        <button type="submit" class="btn btn--primary">Update Password</button>
      </form>
    </div>
  </div>
</div>

<!-- Signed Agreements -->
<div class="card" style="margin-top: 1.5rem;">
  <div class="card__header" style="padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);">
    <h3 style="font-size: 0.95rem; font-weight: 600;">Signed Agreements</h3>
  </div>
  <div style="padding: 1.25rem;">
    <% if (typeof myAgreements !== 'undefined' && myAgreements && myAgreements.length > 0) { %>
      <% myAgreements.forEach(a => { %>
      <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid var(--border);">
        <div>
          <strong style="font-size: 0.9rem;"><%= a.agreement_type === 'volunteer_service' ? 'Volunteer Service Agreement' : a.agreement_type.replace(/_/g, ' ') %></strong>
          <div style="font-size: 0.75rem; color: var(--text-muted);">Signed <%= new Date(a.signed_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
        </div>
        <span style="color: var(--primary); font-size: 0.8rem; font-weight: 600;">✓ Signed</span>
      </div>
      <% }); %>
    <% } else { %>
      <p style="color: var(--text-muted); font-size: 0.85rem;">No agreements on file.</p>
    <% } %>
  </div>
</div>

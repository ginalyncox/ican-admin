<div class="page-header">
  <h1 class="page-title">Welcome to ICAN!</h1>
  <p class="page-subtitle">Let's get you set up, <%= member.name %>. Just a few quick steps.</p>
</div>

<% const personalDone = gardener.phone && gardener.email && gardener.emergency_contact_name; %>
<% const prefsDone = !!gardener.availability; %>
<% const programsDone = appliedPrograms.length > 0; %>
<% const docsDone = !!cred.documents_acknowledged; %>

<!-- Progress Steps (6 steps) -->
<div class="onboarding-progress">
  <div class="onboarding-step <%= step === 'password' ? 'onboarding-step--active' : (cred.must_change_password ? '' : 'onboarding-step--done') %>">
    <div class="onboarding-step__number"><% if (!cred.must_change_password) { %>&#10003;<% } else { %>1<% } %></div>
    <div class="onboarding-step__label">Set Password</div>
  </div>
  <div class="onboarding-step__line <%= !cred.must_change_password ? 'onboarding-step__line--done' : '' %>"></div>
  <div class="onboarding-step <%= step === 'personal' ? 'onboarding-step--active' : (personalDone ? 'onboarding-step--done' : '') %>">
    <div class="onboarding-step__number"><% if (personalDone) { %>&#10003;<% } else { %>2<% } %></div>
    <div class="onboarding-step__label">Personal Info</div>
  </div>
  <div class="onboarding-step__line <%= personalDone ? 'onboarding-step__line--done' : '' %>"></div>
  <div class="onboarding-step <%= step === 'preferences' ? 'onboarding-step--active' : (prefsDone ? 'onboarding-step--done' : '') %>">
    <div class="onboarding-step__number"><% if (prefsDone) { %>&#10003;<% } else { %>3<% } %></div>
    <div class="onboarding-step__label">Preferences</div>
  </div>
  <div class="onboarding-step__line <%= prefsDone ? 'onboarding-step__line--done' : '' %>"></div>
  <div class="onboarding-step <%= step === 'programs' ? 'onboarding-step--active' : (programsDone ? 'onboarding-step--done' : '') %>">
    <div class="onboarding-step__number"><% if (programsDone) { %>&#10003;<% } else { %>4<% } %></div>
    <div class="onboarding-step__label">Programs</div>
  </div>
  <div class="onboarding-step__line <%= programsDone ? 'onboarding-step__line--done' : '' %>"></div>
  <div class="onboarding-step <%= step === 'documents' ? 'onboarding-step--active' : (docsDone ? 'onboarding-step--done' : '') %>">
    <div class="onboarding-step__number"><% if (docsDone) { %>&#10003;<% } else { %>5<% } %></div>
    <div class="onboarding-step__label">Documents</div>
  </div>
  <div class="onboarding-step__line <%= docsDone ? 'onboarding-step__line--done' : '' %>"></div>
  <div class="onboarding-step <%= step === 'agreement' ? 'onboarding-step--active' : (cred.agreement_signed ? 'onboarding-step--done' : '') %>">
    <div class="onboarding-step__number"><% if (cred.agreement_signed) { %>&#10003;<% } else { %>6<% } %></div>
    <div class="onboarding-step__label">Agreement</div>
  </div>
  <div class="onboarding-step__line <%= cred.agreement_signed ? 'onboarding-step__line--done' : '' %>"></div>
  <div class="onboarding-step <%= step === 'welcome' ? 'onboarding-step--active' : '' %>">
    <div class="onboarding-step__number">7</div>
    <div class="onboarding-step__label">Get Started</div>
  </div>
</div>

<!-- Step 1: Change Password -->
<% if (step === 'password') { %>
<div class="card onboarding-card">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Step 1: Create Your Password
    </h2>
  </div>
  <div class="card__body">
    <p style="margin-bottom:1.5rem; color: var(--color-muted);">Your account was created with a temporary password. Please choose a secure password that only you know.</p>
    <form method="POST" action="/member/onboarding/password">
      <div class="form-group">
        <label for="new_password">New Password</label>
        <input type="password" id="new_password" name="new_password" class="form-control" required minlength="8" placeholder="At least 8 characters">
      </div>
      <div class="form-group">
        <label for="confirm_password">Confirm Password</label>
        <input type="password" id="confirm_password" name="confirm_password" class="form-control" required minlength="8" placeholder="Type it again">
      </div>
      <button type="submit" class="btn btn--primary">Set Password &amp; Continue</button>
    </form>
  </div>
</div>
<% } %>

<!-- Step 2: Personal Information -->
<% if (step === 'personal') { %>
<div class="card onboarding-card">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Step 2: Personal Information
    </h2>
  </div>
  <div class="card__body">
    <p style="margin-bottom:1.5rem; color: var(--color-muted);">We need your contact info so coordinators can reach you.</p>
    <form method="POST" action="/member/onboarding/personal">
      <div class="form-row">
        <div class="form-group">
          <label>Name</label>
          <input type="text" class="form-control" value="<%= gardener.first_name %> <%= gardener.last_name %>" disabled>
        </div>
      </div>
      <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label for="email">Email <span style="color:#c0392b;">*</span></label>
          <input type="email" id="email" name="email" class="form-control" required value="<%= gardener.email || '' %>" placeholder="your@email.com">
        </div>
        <div class="form-group">
          <label for="phone">Phone <span style="color:#c0392b;">*</span></label>
          <input type="tel" id="phone" name="phone" class="form-control" required value="<%= gardener.phone || '' %>" placeholder="(515) 555-0100">
        </div>
      </div>
      <div class="form-group">
        <label for="address">Street Address</label>
        <input type="text" id="address" name="address" class="form-control" value="<%= gardener.address || '' %>" placeholder="123 Main St">
      </div>
      <div class="form-row" style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label for="city">City</label>
          <input type="text" id="city" name="city" class="form-control" value="<%= gardener.city || '' %>" placeholder="Des Moines">
        </div>
        <div class="form-group">
          <label for="state">State</label>
          <input type="text" id="state" name="state" class="form-control" value="<%= gardener.state || 'IA' %>" placeholder="IA" maxlength="2">
        </div>
        <div class="form-group">
          <label for="zip">Zip</label>
          <input type="text" id="zip" name="zip" class="form-control" value="<%= gardener.zip || '' %>" placeholder="50309" maxlength="10">
        </div>
      </div>
      <div class="form-group">
        <label for="date_of_birth">Date of Birth</label>
        <input type="date" id="date_of_birth" name="date_of_birth" class="form-control" value="<%= gardener.date_of_birth || '' %>">
      </div>
      <hr style="margin: 1.5rem 0; border-color: var(--color-border);">
      <p style="margin-bottom:1rem; font-weight:600;">Emergency Contact <span style="color:#c0392b;">*</span></p>
      <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label for="emergency_contact_name">Name <span style="color:#c0392b;">*</span></label>
          <input type="text" id="emergency_contact_name" name="emergency_contact_name" class="form-control" required value="<%= gardener.emergency_contact_name || '' %>" placeholder="Jane Doe">
        </div>
        <div class="form-group">
          <label for="emergency_contact_phone">Phone <span style="color:#c0392b;">*</span></label>
          <input type="tel" id="emergency_contact_phone" name="emergency_contact_phone" class="form-control" required value="<%= gardener.emergency_contact_phone || '' %>" placeholder="(515) 555-0200">
        </div>
      </div>
      <button type="submit" class="btn btn--primary">Save &amp; Continue</button>
    </form>
  </div>
</div>
<% } %>

<!-- Step 3: Volunteer Preferences -->
<% if (step === 'preferences') { %>
<div class="card onboarding-card">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>
      Step 3: Volunteer Preferences
    </h2>
  </div>
  <div class="card__body">
    <p style="margin-bottom:1.5rem; color: var(--color-muted);">Help us match you with the right volunteer opportunities.</p>
    <form method="POST" action="/member/onboarding/preferences">
      <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label for="tshirt_size">T-Shirt Size</label>
          <select id="tshirt_size" name="tshirt_size" class="form-control">
            <option value="">— Select —</option>
            <option value="XS" <%= gardener.tshirt_size === 'XS' ? 'selected' : '' %>>XS</option>
            <option value="S" <%= gardener.tshirt_size === 'S' ? 'selected' : '' %>>S</option>
            <option value="M" <%= gardener.tshirt_size === 'M' ? 'selected' : '' %>>M</option>
            <option value="L" <%= gardener.tshirt_size === 'L' ? 'selected' : '' %>>L</option>
            <option value="XL" <%= gardener.tshirt_size === 'XL' ? 'selected' : '' %>>XL</option>
            <option value="2XL" <%= gardener.tshirt_size === '2XL' ? 'selected' : '' %>>2XL</option>
            <option value="3XL" <%= gardener.tshirt_size === '3XL' ? 'selected' : '' %>>3XL</option>
          </select>
        </div>
        <div class="form-group">
          <label for="availability">Availability <span style="color:#c0392b;">*</span></label>
          <select id="availability" name="availability" class="form-control" required>
            <option value="">— Select —</option>
            <option value="weekdays" <%= gardener.availability === 'weekdays' ? 'selected' : '' %>>Weekdays</option>
            <option value="weekends" <%= gardener.availability === 'weekends' ? 'selected' : '' %>>Weekends</option>
            <option value="evenings" <%= gardener.availability === 'evenings' ? 'selected' : '' %>>Evenings</option>
            <option value="flexible" <%= gardener.availability === 'flexible' ? 'selected' : '' %>>Flexible</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label for="how_heard">How did you hear about ICAN?</label>
        <input type="text" id="how_heard" name="how_heard" class="form-control" value="<%= gardener.how_heard || '' %>" placeholder="Friend, social media, event, etc.">
      </div>
      <div class="form-group">
        <label for="skills">Skills or Interests</label>
        <textarea id="skills" name="skills" class="form-control" rows="3" placeholder="Gardening, event planning, social media, graphic design, etc."><%= gardener.skills || '' %></textarea>
      </div>

      <hr style="margin: 1.5rem 0; border-color: var(--color-border);">
      <p style="margin-bottom:1rem; font-weight:600;">Agreements</p>
      <div class="form-group">
        <label style="display:flex; align-items:flex-start; gap:0.5rem; font-weight:normal; cursor:pointer;">
          <input type="checkbox" name="background_check_consent" value="1" <%= gardener.background_check_consent ? 'checked' : '' %> style="margin-top:3px;">
          <span>I consent to a background check if required for my volunteer role</span>
        </label>
      </div>
      <div class="form-group">
        <label style="display:flex; align-items:flex-start; gap:0.5rem; font-weight:normal; cursor:pointer;">
          <input type="checkbox" name="photo_release_consent" value="1" <%= gardener.photo_release_consent ? 'checked' : '' %> style="margin-top:3px;">
          <span>I grant permission for ICAN to use photos of me in publications and social media</span>
        </label>
      </div>
      <div class="form-group">
        <label style="display:flex; align-items:flex-start; gap:0.5rem; font-weight:normal; cursor:pointer;">
          <input type="checkbox" name="liability_waiver_signed" value="1" <%= gardener.liability_waiver_signed ? 'checked' : '' %> style="margin-top:3px;">
          <span>I acknowledge the volunteer liability waiver</span>
        </label>
      </div>

      <button type="submit" class="btn btn--primary">Save Preferences &amp; Continue</button>
    </form>
  </div>
</div>
<% } %>

<!-- Step 4: Program Interests -->
<% if (step === 'programs') { %>
<div class="card onboarding-card">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
      Step 4: Choose Your Programs
    </h2>
  </div>
  <div class="card__body">
    <p style="margin-bottom:1.5rem; color: var(--color-muted);">Select the volunteer programs you're interested in. Your application will be reviewed by a coordinator.</p>
    <form method="POST" action="/member/onboarding/programs">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
        <% Object.entries(programInfo).forEach(([key, info]) => { %>
          <label style="display:flex; align-items:flex-start; gap:0.75rem; padding:1rem; border:2px solid var(--color-border); border-radius:8px; cursor:pointer; transition: border-color 0.15s;" onmouseover="this.style.borderColor='<%= info.color %>'" onmouseout="if(!this.querySelector('input').checked) this.style.borderColor='var(--color-border)'" onclick="var cb=this.querySelector('input'); setTimeout(function(){if(cb.checked) cb.closest('label').style.borderColor='<%= info.color %>'; else cb.closest('label').style.borderColor='var(--color-border)';}, 0);">
            <input type="checkbox" name="programs" value="<%= key %>" <%= appliedPrograms.includes(key) ? 'checked' : '' %> style="margin-top:2px;">
            <div>
              <strong style="color: <%= info.color %>;"><%= info.label %></strong>
              <p style="margin:0.25rem 0 0; font-size:0.85rem; color: var(--color-muted); line-height:1.4;"><%= info.description %></p>
            </div>
          </label>
        <% }) %>
      </div>
      <p style="font-size:0.85rem; color: var(--color-muted); margin-bottom:1.25rem;">You can apply for additional programs at any time from your portal.</p>
      <button type="submit" class="btn btn--primary">Submit Applications &amp; Continue</button>
    </form>
  </div>
</div>
<% } %>

<!-- Step 5: Document Acknowledgment -->
<% if (step === 'documents') { %>
<div class="card onboarding-card">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      Step 5: Review &amp; Acknowledge Documents
    </h2>
  </div>
  <div class="card__body">
    <p style="margin-bottom:1rem; color: var(--color-muted);">Please download and review each volunteer document below, then check the box to confirm you received it. These documents remain available in your Resources section after onboarding.</p>

    <form method="POST" action="/member/onboarding/documents" id="memberDocAckForm">
    <% if (volDocs && volDocs.length > 0) { %>
      <div style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1.5rem;">
        <% volDocs.forEach(function(doc) { %>
          <div style="display:flex; align-items:flex-start; gap:0.75rem; padding:1rem; border:1px solid var(--color-border); border-radius:8px; background:#fff;">
            <input type="checkbox" name="acknowledged_docs" value="<%= doc.id %>" id="vol-ack-<%= doc.id %>" class="vol-doc-ack-check" style="margin-top:3px; width:18px; height:18px; accent-color:#2D6A3F; cursor:pointer;">
            <div style="flex:1;">
              <label for="vol-ack-<%= doc.id %>" style="font-weight:600; cursor:pointer; display:block; margin-bottom:0.25rem;"><%= doc.title %></label>
              <span class="badge badge--<%= doc.category %>" style="font-size:0.7rem;"><%= doc.category %></span>
            </div>
            <a href="/member/resources/<%= doc.id %>/download" class="btn btn--outline btn--sm" target="_blank" style="white-space:nowrap;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download
            </a>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p class="text-muted" style="margin-bottom:1rem;">No volunteer documents have been uploaded yet. Your administrator will add these soon.</p>
    <% } %>

      <div style="padding:1.25rem; background: rgba(45,106,63,0.08); border-radius:8px; border: 1px solid rgba(45,106,63,0.15);">
        <p style="margin:0 0 1rem; font-size:0.9rem; color: var(--color-muted);">By checking each box above and clicking below, you confirm that you have received, downloaded, and agree to review the ICAN volunteer documents.</p>
        <button type="submit" class="btn btn--primary" id="memberDocAckSubmit" <%= (volDocs && volDocs.length > 0) ? 'disabled' : '' %>>I Acknowledge Receipt of All Documents</button>
      </div>
    </form>

    <script>
    (function() {
      var checks = document.querySelectorAll('.vol-doc-ack-check');
      var btn = document.getElementById('memberDocAckSubmit');
      if (!checks.length) return; // No docs, button already enabled
      function update() {
        var all = true;
        checks.forEach(function(c) { if (!c.checked) all = false; });
        btn.disabled = !all;
        btn.style.opacity = all ? '1' : '0.5';
      }
      checks.forEach(function(c) { c.addEventListener('change', update); });
      update();
    })();
    </script>
  </div>
</div>
<% } %>


<!-- Step 6: Volunteer Service Agreement -->
<% if (step === 'agreement') { %>
<div class="card onboarding-card">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      Step 6: Volunteer Service Agreement
    </h2>
  </div>
  <div class="card__body">
    <p style="margin-bottom:1rem; color: var(--color-muted);">Please read and accept the Volunteer Service Agreement below. This is required before accessing your portal.</p>

    <div style="background: #fff; border: 1px solid var(--color-border); border-radius: 8px; padding: 1.5rem; max-height: 350px; overflow-y: auto; margin-bottom: 1.5rem; font-size: 0.88rem; line-height: 1.7;">
      <h3 style="color: var(--primary); margin-bottom: 0.75rem; font-size: 1rem;">Volunteer Service Agreement</h3>
      <p style="color: var(--color-muted); margin-bottom: 0.75rem;">Iowa Cannabis Action Network, Inc.</p>

      <p style="margin-bottom: 0.75rem;">By signing this agreement, I voluntarily offer my services to ICAN and agree to the following:</p>
      <ol style="padding-left: 1.25rem; margin-bottom: 1rem;">
        <li style="margin-bottom: 0.5rem;">I will perform my volunteer duties to the best of my ability.</li>
        <li style="margin-bottom: 0.5rem;">I understand that I am not an employee of ICAN and will not receive compensation.</li>
        <li style="margin-bottom: 0.5rem;">I agree to follow all ICAN policies, including the Code of Conduct and safety protocols.</li>
        <li style="margin-bottom: 0.5rem;">I will maintain the confidentiality of any sensitive information I encounter.</li>
        <li style="margin-bottom: 0.5rem;">I understand that ICAN may terminate my volunteer service at any time.</li>
        <li style="margin-bottom: 0.5rem;">I will report any injuries, safety concerns, or incidents to my program coordinator.</li>
        <li style="margin-bottom: 0.5rem;">I agree to accurately log my volunteer hours in the ICAN Volunteer Portal.</li>
      </ol>

      <h4 style="color: var(--primary); margin-bottom: 0.5rem; font-size: 0.92rem;">Release and Waiver</h4>
      <p>I release and hold harmless Iowa Cannabis Action Network, Inc., its officers, directors, agents, and other volunteers from any and all claims arising out of my volunteer activities, except those caused by willful misconduct.</p>
    </div>

    <form method="POST" action="/member/onboarding/agreement">
      <div style="padding: 1.25rem; background: rgba(45,106,63,0.08); border-radius: 8px; border: 1px solid rgba(45,106,63,0.15);">
        <label style="display: flex; align-items: flex-start; gap: 0.75rem; cursor: pointer; margin-bottom: 1rem;">
          <input type="checkbox" name="agree_terms" value="1" id="agreeCheck" style="margin-top: 3px; width: 18px; height: 18px; accent-color: #2D6A3F;">
          <span style="font-size: 0.9rem;">I have read, understand, and agree to the terms of the Volunteer Service Agreement above.</span>
        </label>
        <div class="form-group" style="margin-bottom: 1rem;">
          <label for="printed_name" style="font-weight: 600; font-size: 0.85rem;">Print Your Full Legal Name (Electronic Signature)</label>
          <input type="text" id="printed_name" name="printed_name" class="form-control" required placeholder="Your full name as your electronic signature" value="<%= gardener.first_name %> <%= gardener.last_name %>">
        </div>
        <p style="font-size: 0.75rem; color: var(--color-muted); margin-bottom: 1rem;">
          By typing your name and clicking below, you are electronically signing this agreement.
          Your IP address and timestamp will be recorded.
        </p>
        <button type="submit" class="btn btn--primary" id="agreeBtn" disabled style="opacity: 0.5;">Sign Agreement &amp; Continue</button>
      </div>
    </form>

    <script>
    document.getElementById('agreeCheck').addEventListener('change', function() {
      var btn = document.getElementById('agreeBtn');
      btn.disabled = !this.checked;
      btn.style.opacity = this.checked ? '1' : '0.5';
    });
    </script>
  </div>
</div>
<% } %>

<!-- Step 7: Welcome & Finish -->
<% if (step === 'welcome') { %>
<div class="card onboarding-card">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      You're All Set!
    </h2>
  </div>
  <div class="card__body">
    <div style="padding:1.25rem; background: rgba(45,106,63,0.08); border-radius:8px; border: 1px solid rgba(45,106,63,0.15); margin-bottom:1.5rem;">
      <h3 style="margin:0 0 0.75rem; font-size:1.05rem; color: var(--primary);">Welcome to the ICAN Volunteer Portal!</h3>
      <p style="margin:0 0 1rem; font-size:0.9rem; color: var(--color-muted);">Your program applications have been submitted. A coordinator will review them soon. Here's what you can do:</p>
      <ul style="margin:0; padding-left:1.25rem; font-size:0.9rem; color: var(--color-muted); line-height:1.8;">
        <li><strong>Dashboard</strong> &mdash; See your assigned programs and pending applications</li>

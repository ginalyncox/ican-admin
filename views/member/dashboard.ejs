<div class="page-header">
  <h1 class="page-header__title">Welcome, <%= gardener.first_name %></h1>
  <p class="page-header__subtitle">Your volunteer dashboard</p>
</div>

<% if (pendingApplications && pendingApplications.length > 0) { %>
<div class="card" style="margin-bottom: 1.5rem; border-left: 3px solid var(--accent);">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Pending Applications
    </h2>
  </div>
  <div class="card__body">
    <p style="font-size: 0.9rem; color: var(--color-muted); margin-bottom: 0.75rem;">Your applications are being reviewed by a coordinator.</p>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
      <% pendingApplications.forEach(pa => { %>
        <% const info = programInfo[pa.program] || { label: pa.program, color: '#666' }; %>
        <span class="badge" style="background: <%= info.color %>; color: #fff; padding: 0.35rem 0.75rem;"><%= info.label %></span>
      <% }); %>
    </div>
  </div>
</div>
<% } %>

<!-- Total Hours Summary (across all programs) -->
<% if (programs.length > 0) { %>
<div class="stats-grid stats-grid--4" style="margin-bottom: 1.5rem;">
  <div class="stat-card">
    <div class="stat-card__label">Total Hours</div>
    <div class="stat-card__value"><%= Number(stats.totalHrs).toFixed(1) %></div>
    <div class="stat-card__detail">Across all programs</div>
  </div>
  <% if (programs.includes('victory_garden')) { %>
  <div class="stat-card">
    <div class="stat-card__label">Lbs Harvested</div>
    <div class="stat-card__value"><%= Number(stats.totalLbs).toFixed(1) %></div>
    <div class="stat-card__detail"><%= Number(stats.totalDonatedLbs).toFixed(1) %> donated</div>
  </div>
  <% } %>
  <div class="stat-card">
    <div class="stat-card__label">Programs</div>
    <div class="stat-card__value"><%= programs.length %></div>
    <div class="stat-card__detail"><a href="/member/programs">View all &rarr;</a></div>
  </div>
  <% if (programs.includes('victory_garden')) { %>
  <div class="stat-card">
    <div class="stat-card__label">Awards</div>
    <div class="stat-card__value"><%= stats.awardCount %></div>
    <div class="stat-card__detail"><a href="/member/awards">View &rarr;</a></div>
  </div>
  <% } %>
</div>
<% } %>

<%
const programIcons = {
  victory_garden: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>',
  legislative: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/></svg>',
  outreach: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  fundraising: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
  communications: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
  membership: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>'
};
const hbp = typeof hoursByProgram !== 'undefined' ? hoursByProgram : {};
%>

<!-- Program Cards -->
<div class="portal-grid" style="margin-bottom: 1.5rem;">
  <% programs.forEach(prog => { %>
    <% const info = programInfo[prog] || { label: prog, color: '#666', description: '' }; %>
    <% const progHrs = hbp[prog] || 0; %>
    <div class="card">
      <div class="card__header" style="border-left: 3px solid <%= info.color %>;">
        <h2 class="card__title" style="color: <%= info.color %>;">
          <%- programIcons[prog] || '' %>
          <%= info.label %>
        </h2>
      </div>
      <div class="card__body">
        <% if (prog === 'victory_garden') { %>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 1rem;">
            <div style="text-align: center;">
              <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= Number(stats.totalLbs).toFixed(1) %></div>
              <div style="font-size: 0.75rem; color: var(--color-muted);">Lbs Harvested</div>
            </div>
            <div style="text-align: center;">
              <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= Number(stats.totalDonatedLbs).toFixed(1) %></div>
              <div style="font-size: 0.75rem; color: var(--color-muted);">Lbs Donated</div>
            </div>
            <div style="text-align: center;">
              <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= Number(progHrs).toFixed(1) %></div>
              <div style="font-size: 0.75rem; color: var(--color-muted);">Hours</div>
            </div>
          </div>
          <% if (gardener.site_name) { %>
            <p style="font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.75rem;">
              <%= gardener.site_name %><%= gardener.plot_number ? ' &middot; Plot ' + gardener.plot_number : '' %>
            </p>
          <% } %>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <a href="/member/log-harvest" class="btn btn--primary btn--sm">Log Harvest</a>
            <a href="/member/log-hours?program=victory_garden" class="btn btn--outline btn--sm">Log Hours</a>
            <a href="/member/leaderboard" class="btn btn--ghost btn--sm">Leaderboard</a>
          </div>
        <% } else { %>
          <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.75rem;">
            <div style="font-size: 1.5rem; font-weight: 700; color: <%= info.color %>;"><%= Number(progHrs).toFixed(1) %></div>
            <div style="font-size: 0.85rem; color: var(--color-muted);">hours logged</div>
          </div>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <a href="/member/log-hours?program=<%= prog %>" class="btn btn--outline btn--sm">Log Hours</a>
          </div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<% if (programs.length === 0 && (!pendingApplications || pendingApplications.length === 0)) { %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card__body" style="text-align: center; padding: 2rem;">
    <p style="font-size: 1.1rem; color: var(--color-muted); margin-bottom: 0.5rem;">No programs assigned yet.</p>
    <p style="font-size: 0.85rem; color: var(--color-muted);">
      <a href="/member/programs" style="color: var(--primary);">Apply for programs</a> or check back after a coordinator reviews your application.
    </p>
  </div>
</div>
<% } %>

<% if (programs.includes('victory_garden') && awards.length > 0) { %>
<div class="card" style="margin-bottom:1.5rem">
  <div class="card__header"><h2 class="card__title">My Awards</h2></div>
  <div class="card__body">
    <% awards.forEach(a => { %>
      <div class="award-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        <div>
          <strong><%= a.award_name %></strong>
          <span class="text-muted"> &mdash; <%= a.category %><%= a.season_name ? ' (' + a.season_name + ')' : '' %></span>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Recent Activity -->
<div class="dashboard-grid">
  <% if (programs.includes('victory_garden')) { %>
  <div class="card">
    <div class="card__header"><h2 class="card__title">Recent Harvests</h2></div>
    <div class="card__body">
      <% if (recentHarvests.length === 0) { %>
        <p class="empty-state">No harvests logged yet.</p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>Date</th><th>Crop</th><th>Lbs</th><th>Donated To</th></tr></thead>
          <tbody>
            <% recentHarvests.forEach(h => { %>
              <tr>
                <td><%= h.harvest_date %></td>
                <td><%= h.crop %></td>
                <td><strong><%= h.pounds %></strong></td>
                <td><%= h.donated_to || (h.donated ? 'Yes' : '—') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
  <% } %>

  <div class="card">
    <div class="card__header"><h2 class="card__title">Recent Hours</h2></div>
    <div class="card__body">
      <% if (recentHours.length === 0) { %>
        <p class="empty-state">No hours logged yet. <a href="/member/log-hours">Log your first hours</a></p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>Date</th><th>Program</th><th>Hours</th><th>Activity</th></tr></thead>
          <tbody>
            <% recentHours.forEach(h => { %>
              <% const pInfo = programInfo[h.program || 'victory_garden'] || { label: h.program || 'Victory Garden' }; %>
              <tr>
                <td><%= h.work_date %></td>
                <td><span class="badge" style="font-size: 0.7rem;"><%= pInfo.label %></span></td>
                <td><strong><%= h.hours %></strong></td>
                <td><%= h.activity || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

<div class="page-header">
  <h1 class="page-header__title">Welcome, <%= gardener.first_name %></h1>
  <p class="page-header__subtitle">Your volunteer dashboard</p>
</div>

<% if (pendingApplications && pendingApplications.length > 0) { %>
<div class="card" style="margin-bottom: 1.5rem; border-left: 3px solid var(--accent);">
  <div class="card__header">
    <h2 class="card__title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Pending Applications
    </h2>
  </div>
  <div class="card__body">
    <p style="font-size: 0.9rem; color: var(--color-muted); margin-bottom: 0.75rem;">Your applications are being reviewed by a coordinator.</p>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
      <% pendingApplications.forEach(pa => { %>
        <% const info = programInfo[pa.program] || { label: pa.program, color: '#666' }; %>
        <span class="badge" style="background: <%= info.color %>; color: #fff; padding: 0.35rem 0.75rem;"><%= info.label %></span>
      <% }); %>
    </div>
  </div>
</div>
<% } %>

<!-- Program Cards -->
<div class="portal-grid" style="margin-bottom: 1.5rem;">
  <% if (programs.includes('victory_garden')) { %>
  <div class="card">
    <div class="card__header" style="border-left: 3px solid var(--primary);">
      <h2 class="card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>
        Victory Garden
      </h2>
    </div>
    <div class="card__body">
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 1rem;">
        <div style="text-align: center;">
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= Number(stats.totalLbs).toFixed(1) %></div>
          <div style="font-size: 0.75rem; color: var(--color-muted);">Lbs Harvested</div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= Number(stats.totalDonatedLbs).toFixed(1) %></div>
          <div style="font-size: 0.75rem; color: var(--color-muted);">Lbs Donated</div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= Number(stats.totalHrs).toFixed(1) %></div>
          <div style="font-size: 0.75rem; color: var(--color-muted);">Hours</div>
        </div>
      </div>
      <% if (gardener.site_name) { %>
        <p style="font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.75rem;">
          <%= gardener.site_name %><%= gardener.plot_number ? ' &middot; Plot ' + gardener.plot_number : '' %>
        </p>
      <% } %>
      <details style="margin-bottom: 0.75rem;">
        <summary style="font-size: 0.9rem; color: var(--color-muted); cursor: pointer; padding: 0.25rem 0;">Volunteer Instructions</summary>
        <ul style="font-size: 0.85rem; color: var(--color-muted); margin: 0.5rem 0 0 1.25rem; padding: 0; line-height: 1.6;">
          <li>Log all harvests promptly using the Log Harvest button</li>
          <li>Record volunteer hours after each garden work session</li>
          <li>Donate surplus produce to approved community partners</li>
          <li>Keep your plot maintained and free of weeds</li>
          <li>Attend scheduled garden workdays and seasonal events</li>
          <li>Follow organic gardening practices — no synthetic pesticides</li>
        </ul>
      </details>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <a href="/member/log-harvest" class="btn btn--primary btn--sm">Log Harvest</a>
        <a href="/member/log-hours" class="btn btn--outline btn--sm">Log Hours</a>
        <a href="/member/leaderboard" class="btn btn--ghost btn--sm">Leaderboard</a>
      </div>
    </div>
  </div>
  <% } %>

  <% if (programs.includes('legislative')) { %>
  <div class="card">
    <div class="card__header" style="border-left: 3px solid #6366f1;">
      <h2 class="card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/></svg>
        Legislative Action
      </h2>
    </div>
    <div class="card__body">
      <details style="margin-bottom: 0;">
        <summary style="font-size: 0.9rem; color: var(--color-muted); cursor: pointer; padding: 0.25rem 0;">Volunteer Instructions</summary>
        <ul style="font-size: 0.85rem; color: var(--color-muted); margin: 0.5rem 0 0 1.25rem; padding: 0; line-height: 1.6;">
          <li>Contact your local legislators about cannabis reform bills</li>
          <li>Attend town halls and public hearings when scheduled</li>
          <li>Distribute ICAN-approved talking points to community members</li>
          <li>Report back on meetings and conversations with officials</li>
          <li>Help organize letter-writing and phone-call campaigns</li>
        </ul>
      </details>
    </div>
  </div>
  <% } %>

  <% if (programs.includes('outreach')) { %>
  <div class="card">
    <div class="card__header" style="border-left: 3px solid #f59e0b;">
      <h2 class="card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Community Outreach
      </h2>
    </div>
    <div class="card__body">
      <details style="margin-bottom: 0;">
        <summary style="font-size: 0.9rem; color: var(--color-muted); cursor: pointer; padding: 0.25rem 0;">Volunteer Instructions</summary>
        <ul style="font-size: 0.85rem; color: var(--color-muted); margin: 0.5rem 0 0 1.25rem; padding: 0; line-height: 1.6;">
          <li>Staff ICAN booths at farmers markets and community events</li>
          <li>Distribute brochures and educational materials to the public</li>
          <li>Organize or attend neighborhood informational sessions</li>
          <li>Build relationships with local businesses and organizations</li>
          <li>Collect contact info from interested community members</li>
        </ul>
      </details>
    </div>
  </div>
  <% } %>

  <% if (programs.includes('fundraising')) { %>
  <div class="card">
    <div class="card__header" style="border-left: 3px solid #10b981;">
      <h2 class="card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        Fundraising
      </h2>
    </div>
    <div class="card__body">
      <details style="margin-bottom: 0;">
        <summary style="font-size: 0.9rem; color: var(--color-muted); cursor: pointer; padding: 0.25rem 0;">Volunteer Instructions</summary>
        <ul style="font-size: 0.85rem; color: var(--color-muted); margin: 0.5rem 0 0 1.25rem; padding: 0; line-height: 1.6;">
          <li>Help plan and execute fundraising events</li>
          <li>Reach out to potential donors and sponsors</li>
          <li>Assist with online crowdfunding campaigns</li>
          <li>Track donations and send thank-you notes</li>
          <li>Brainstorm new fundraising ideas with the team</li>
        </ul>
      </details>
    </div>
  </div>
  <% } %>

  <% if (programs.includes('communications')) { %>
  <div class="card">
    <div class="card__header" style="border-left: 3px solid #8b5cf6;">
      <h2 class="card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Communications
      </h2>
    </div>
    <div class="card__body">
      <details style="margin-bottom: 0;">
        <summary style="font-size: 0.9rem; color: var(--color-muted); cursor: pointer; padding: 0.25rem 0;">Volunteer Instructions</summary>
        <ul style="font-size: 0.85rem; color: var(--color-muted); margin: 0.5rem 0 0 1.25rem; padding: 0; line-height: 1.6;">
          <li>Write or edit articles for the ICAN newsletter</li>
          <li>Manage and create content for social media accounts</li>
          <li>Draft press releases and public statements</li>
          <li>Photograph events and volunteer activities</li>
          <li>Help maintain the ICAN website content</li>
        </ul>
      </details>
    </div>
  </div>
  <% } %>

  <% if (programs.includes('membership')) { %>
  <div class="card">
    <div class="card__header" style="border-left: 3px solid #ec4899;">
      <h2 class="card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Membership
      </h2>
    </div>
    <div class="card__body">
      <details style="margin-bottom: 0;">
        <summary style="font-size: 0.9rem; color: var(--color-muted); cursor: pointer; padding: 0.25rem 0;">Volunteer Instructions</summary>
        <ul style="font-size: 0.85rem; color: var(--color-muted); margin: 0.5rem 0 0 1.25rem; padding: 0; line-height: 1.6;">
          <li>Welcome and orient new ICAN members</li>
          <li>Follow up with lapsed members to encourage renewal</li>
          <li>Organize member appreciation events</li>
          <li>Maintain accurate membership records and contact info</li>
          <li>Recruit new members at events and through personal networks</li>
        </ul>
      </details>
    </div>
  </div>
  <% } %>
</div>

<% if (programs.length === 0 && (!pendingApplications || pendingApplications.length === 0)) { %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card__body" style="text-align: center; padding: 2rem;">
    <p style="font-size: 1.1rem; color: var(--color-muted); margin-bottom: 0.5rem;">No programs assigned yet.</p>
    <p style="font-size: 0.85rem; color: var(--color-muted);">
      <a href="/member/programs" style="color: var(--primary);">Apply for programs</a> or check back after a coordinator reviews your application.
    </p>
  </div>
</div>
<% } %>

<% if (programs.includes('victory_garden') && awards.length > 0) { %>
<div class="card" style="margin-bottom:1.5rem">
  <div class="card__header"><h2 class="card__title">My Awards</h2></div>
  <div class="card__body">
    <% awards.forEach(a => { %>
      <div class="award-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        <div>
          <strong><%= a.award_name %></strong>
          <span class="text-muted"> &mdash; <%= a.category %><%= a.season_name ? ' (' + a.season_name + ')' : '' %></span>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<% if (programs.includes('victory_garden')) { %>
<div class="dashboard-grid">
  <div class="card">
    <div class="card__header"><h2 class="card__title">Recent Harvests</h2></div>
    <div class="card__body">
      <% if (recentHarvests.length === 0) { %>
        <p class="empty-state">No harvests logged yet.</p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>Date</th><th>Crop</th><th>Lbs</th><th>Donated To</th></tr></thead>
          <tbody>
            <% recentHarvests.forEach(h => { %>
              <tr>
                <td><%= h.harvest_date %></td>
                <td><%= h.crop %></td>
                <td><strong><%= h.pounds %></strong></td>
                <td><%= h.donated_to || (h.donated ? 'Yes' : '—') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card__header"><h2 class="card__title">Recent Hours</h2></div>
    <div class="card__body">
      <% if (recentHours.length === 0) { %>
        <p class="empty-state">No hours logged yet.</p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>Date</th><th>Hours</th><th>Activity</th></tr></thead>
          <tbody>
            <% recentHours.forEach(h => { %>
              <tr>
                <td><%= h.work_date %></td>
                <td><strong><%= h.hours %></strong></td>
                <td><%= h.activity || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>
<% } %>

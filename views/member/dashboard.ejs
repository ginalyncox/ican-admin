<div class="page-header">
  <h1 class="page-header__title">Welcome back, <%= gardener.first_name %></h1>
  <p class="page-header__subtitle">Your volunteer dashboard</p>
</div>

<!-- Quick Actions -->
<div class="quick-actions">
  <a href="/member/log-hours" class="quick-action">
    <span class="quick-action__icon">⏱</span>
    <span class="quick-action__label">Log Hours</span>
  </a>
  <% if (programs.includes('victory_garden')) { %>
  <a href="/member/log-harvest" class="quick-action">
    <span class="quick-action__icon">🌱</span>
    <span class="quick-action__label">Log Harvest</span>
  </a>
  <% } %>
  <a href="/member/events" class="quick-action">
    <span class="quick-action__icon">📅</span>
    <span class="quick-action__label">Events</span>
  </a>
  <a href="/member/mailbox" class="quick-action">
    <span class="quick-action__icon">✉️</span>
    <span class="quick-action__label">Mailbox<% if (unreadMail > 0) { %> (<%= unreadMail %>)<% } %></span>
  </a>
</div>

<!-- Milestone Badges -->
<%
  const milestones = [
    { threshold: 10, label: '10 Hours', icon: '🌿' },
    { threshold: 25, label: '25 Hours', icon: '🌻' },
    { threshold: 50, label: '50 Hours', icon: '⭐' },
    { threshold: 100, label: '100 Hours', icon: '🏆' },
    { threshold: 250, label: '250 Hours', icon: '💎' },
    { threshold: 500, label: '500 Hours', icon: '👑' }
  ];
%>
<div class="card" style="padding: 1rem 1.25rem; margin-bottom: 1.5rem;">
  <h3 style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem;">Hour Milestones</h3>
  <div class="milestone-badges">
    <% milestones.forEach(m => { %>
      <span class="milestone-badge milestone-badge--<%= stats.totalHrs >= m.threshold ? 'earned' : 'locked' %>">
        <span class="milestone-badge__icon"><%= m.icon %></span>
        <%= m.label %>
      </span>
    <% }); %>
  </div>
</div>


<% if (pendingApplications && pendingApplications.length > 0) { %>
<div class="card" style="margin-bottom: 1.5rem; border-left: 3px solid var(--accent);">
  <div class="card__body" style="padding: 0.75rem 1rem;">
    <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span style="font-size: 0.9rem; color: var(--color-muted);">Pending applications:</span>
      <% pendingApplications.forEach(pa => { %>
        <% const info = programInfo[pa.program] || { label: pa.program, color: '#666' }; %>
        <span class="badge" style="background: <%= info.color %>; color: #fff;"><%= info.label %></span>
      <% }); %>
    </div>
  </div>
</div>
<% } %>

<!-- Stat Cards -->
<div class="stats-grid stats-grid--4" style="margin-bottom: 1.5rem;">
  <div class="stat-card">
    <div class="stat-card__label">Total Hours</div>
    <div class="stat-card__value"><%= Number(stats.totalHrs).toFixed(1) %></div>
    <div class="stat-card__detail">
      <% if (myRank > 0) { %>Rank #<%= myRank %> of <%= totalVolunteers %><% } else { %>Across all programs<% } %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">This Month</div>
    <div class="stat-card__value"><%= Number(hoursThisMonth).toFixed(1) %></div>
    <div class="stat-card__detail"><%= new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Programs</div>
    <div class="stat-card__value"><%= programs.length %></div>
    <div class="stat-card__detail"><a href="/member/programs">View all &rarr;</a></div>
  </div>
  <% if (programs.includes('victory_garden')) { %>
  <div class="stat-card">
    <div class="stat-card__label">Lbs Harvested</div>
    <div class="stat-card__value"><%= Number(stats.totalLbs).toFixed(1) %></div>
    <div class="stat-card__detail"><%= Number(stats.totalDonatedLbs).toFixed(1) %> donated</div>
  </div>
  <% } else { %>
  <div class="stat-card">
    <div class="stat-card__label">Active Streak</div>
    <div class="stat-card__value"><%= logStreak %></div>
    <div class="stat-card__detail">week<%= logStreak !== 1 ? 's' : '' %> in a row</div>
  </div>
  <% } %>
</div>

<!-- Quick Actions Bar -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card__body" style="padding: 0.75rem 1rem;">
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
      <span style="font-size: 0.85rem; font-weight: 600; color: var(--text); margin-right: 0.25rem;">Quick Actions:</span>
      <a href="/member/log-hours" class="btn btn--primary btn--sm">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -2px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Log Hours
      </a>
      <% if (programs.includes('victory_garden')) { %>
      <a href="/member/log-harvest" class="btn btn--outline btn--sm">Log Harvest</a>
      <% } %>
      <a href="/member/my-hours" class="btn btn--outline btn--sm">View Hour History</a>
      <a href="/member/my-hours/export?format=csv" class="btn btn--outline btn--sm">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -2px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export Report
      </a>
    </div>
  </div>
</div>

<%
const programIcons = {
  victory_garden: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>',
  legislative: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/></svg>',
  outreach: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  fundraising: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
  communications: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
  membership: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>'
};
const hbp = typeof hoursByProgram !== 'undefined' ? hoursByProgram : {};
%>

<!-- Main Content Grid -->
<div class="director-grid">
  <!-- Program Cards -->
  <% if (programs.length > 0) { %>
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">My Programs</h2>
      <a href="/member/programs" class="btn btn--outline btn--sm">Manage</a>
    </div>
    <div class="card__body" style="padding: 0;">
      <% programs.forEach(prog => { %>
        <% const info = programInfo[prog] || { label: prog, color: '#666', description: '' }; %>
        <% const progHrs = hbp[prog] || 0; %>
        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border);">
          <div style="width: 3px; height: 32px; border-radius: 2px; background: <%= info.color %>;"></div>
          <div style="color: <%= info.color %>; flex-shrink: 0;"><%- programIcons[prog] || '' %></div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-weight: 600; font-size: 0.9rem;"><%= info.label %></div>
            <div style="font-size: 0.8rem; color: var(--color-muted);"><%= Number(progHrs).toFixed(1) %> hours logged</div>
          </div>
          <a href="/member/log-hours?program=<%= prog %>" class="btn btn--outline btn--xs">Log</a>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% if (programs.length === 0 && (!pendingApplications || pendingApplications.length === 0)) { %>
  <div class="card">
    <div class="card__body" style="text-align: center; padding: 2rem;">
      <p style="font-size: 1rem; color: var(--color-muted); margin-bottom: 0.5rem;">No programs assigned yet.</p>
      <a href="/member/programs" class="btn btn--primary btn--sm">Apply for Programs</a>
    </div>
  </div>
  <% } %>

  <!-- Recent Announcements / Messages -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Messages <% if (unreadMail > 0) { %><span class="badge" style="background:#c0392b;color:#fff;font-size:0.7rem;vertical-align:middle;margin-left:4px"><%= unreadMail %> new</span><% } %></h2>
      <a href="/member/mailbox" class="btn btn--outline btn--sm">All mail</a>
    </div>
    <div class="card__body">
      <% if (recentAnnouncements.length === 0) { %>
        <p class="text-muted" style="margin: 0;">No recent announcements.</p>
      <% } else { %>
        <% recentAnnouncements.forEach(a => { %>
          <div style="padding: 0.5rem 0; border-bottom: 1px solid var(--color-border);">
            <div style="display: flex; justify-content: space-between; align-items: baseline;">
              <a href="/member/mailbox/<%= a.id %>" style="font-weight: <%= a.read_at ? '400' : '600' %>; color: var(--primary); font-size: 0.9rem;"><%= a.subject %></a>
              <span class="text-muted" style="font-size: 0.75rem; white-space: nowrap;"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
            </div>
            <% if (!a.read_at) { %><span class="badge badge--warning" style="font-size: 0.65rem;">Unread</span><% } %>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Upcoming Events -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Upcoming Events</h2>
      <a href="/member/events" class="btn btn--outline btn--sm">View all</a>
    </div>
    <div class="card__body">
      <% if (upcomingEvents.length === 0) { %>
        <p class="text-muted" style="margin: 0;">No upcoming events.</p>
      <% } else { %>
        <% upcomingEvents.slice(0, 3).forEach(e => { %>
          <div style="display: flex; gap: 0.75rem; padding: 0.5rem 0; border-bottom: 1px solid var(--color-border);">
            <div style="min-width: 44px; text-align: center; background: var(--primary); color: #fff; border-radius: 6px; padding: 4px 6px;">
              <div style="font-size: 1.1rem; font-weight: 700; line-height: 1.1;"><%= new Date(e.event_date + 'T00:00:00').toLocaleDateString('en-US', { day: 'numeric' }) %></div>
              <div style="font-size: 0.65rem; text-transform: uppercase;"><%= new Date(e.event_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short' }) %></div>
            </div>
            <div style="min-width: 0;">
              <div style="font-weight: 600; font-size: 0.9rem;"><%= e.title %></div>
              <div style="font-size: 0.8rem; color: var(--color-muted);">
                <% if (e.event_time) { %><%= e.event_time %><% } %>
                <% if (e.location) { %> &middot; <%= e.location %><% } %>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Recent Hours -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Recent Activity</h2>
      <a href="/member/my-hours" class="btn btn--outline btn--sm">Full history</a>
    </div>
    <div class="card__body">
      <% if (recentHours.length === 0) { %>
        <p class="text-muted" style="margin: 0;">No hours logged yet. <a href="/member/log-hours" style="color: var(--primary);">Log your first hours</a></p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>Date</th><th>Program</th><th>Hours</th><th>Activity</th></tr></thead>
          <tbody>
            <% recentHours.slice(0, 5).forEach(h => { %>
              <% const pInfo = programInfo[h.program || 'victory_garden'] || { label: h.program || 'Victory Garden' }; %>
              <tr>
                <td style="white-space: nowrap;"><%= h.work_date %></td>
                <td><span class="badge" style="font-size: 0.7rem;"><%= pInfo.label %></span></td>
                <td><strong><%= h.hours %></strong></td>
                <td style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= h.activity || '\u2014' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <% if (programs.includes('victory_garden') && recentHarvests.length > 0) { %>
  <!-- Recent Harvests -->
  <div class="card">
    <div class="card__header" style="display: flex; justify-content: space-between; align-items: center;">
      <h2 class="card__title">Recent Harvests</h2>
      <a href="/member/my-harvests" class="btn btn--outline btn--sm" style="font-size: 0.75rem;">View All Harvests</a>
    </div>
    <div class="card__body">
      <table class="table">
        <thead><tr><th>Date</th><th>Crop</th><th>Lbs</th><th>Donated</th></tr></thead>
        <tbody>
          <% recentHarvests.slice(0, 5).forEach(h => { %>
            <tr>
              <td><%= h.harvest_date %></td>
              <td><%= h.crop %></td>
              <td><strong><%= h.pounds %></strong></td>
              <td><%= h.donated_to || (h.donated ? 'Yes' : '\u2014') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <% if (programs.includes('victory_garden') && awards.length > 0) { %>
  <!-- Awards -->
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">My Awards</h2>
      <a href="/member/awards" class="btn btn--outline btn--sm">View all</a>
    </div>
    <div class="card__body">
      <% awards.slice(0, 3).forEach(a => { %>
        <div class="award-badge" style="margin-bottom: 0.5rem;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          <div>
            <strong><%= a.award_name %></strong>
            <span class="text-muted"> &mdash; <%= a.category %><%= a.season_name ? ' (' + a.season_name + ')' : '' %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- Membership Info Card -->
  <div class="card">
    <div class="card__header"><h2 class="card__title">My Membership</h2></div>
    <div class="card__body">
      <div style="display: grid; grid-template-columns: auto 1fr; gap: 0.25rem 1rem; font-size: 0.9rem;">
        <span class="text-muted">Name</span>
        <span style="font-weight: 600;"><%= gardener.first_name %> <%= gardener.last_name %></span>
        <span class="text-muted">Status</span>
        <span><span class="badge badge--success">Active Volunteer</span></span>
        <span class="text-muted">Member Since</span>
        <span><%= new Date(memberSince).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></span>
        <span class="text-muted">Programs</span>
        <span><%= programs.length %> active</span>
        <% if (programs.includes('victory_garden') && gardener.site_name) { %>
        <span class="text-muted">Garden Site</span>
        <span><%= gardener.site_name %><%= gardener.plot_number ? ' \u00b7 Plot ' + gardener.plot_number : '' %></span>
        <% } %>
      </div>
      <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem;">
        <a href="/member/profile" class="btn btn--outline btn--sm">Edit Profile</a>
        <a href="/member/resources" class="btn btn--ghost btn--sm">Resources</a>
      </div>
    </div>
  </div>
</div>

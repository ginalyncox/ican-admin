<div class="page-header">
  <h1 class="page-header__title">Welcome, <%= gardener.first_name %></h1>
  <p class="page-header__subtitle"><%= gardener.site_name || '' %><%= gardener.plot_number ? ' · Plot ' + gardener.plot_number : '' %></p>
</div>

<div class="stats-grid stats-grid--5">
  <div class="stat-card stat-card--garden">
    <div class="stat-card__info">
      <span class="stat-card__value"><%= Number(stats.totalLbs).toFixed(1) %></span>
      <span class="stat-card__label">Lbs Harvested</span>
    </div>
  </div>
  <div class="stat-card stat-card--garden">
    <div class="stat-card__info">
      <span class="stat-card__value"><%= Number(stats.totalDonatedLbs).toFixed(1) %></span>
      <span class="stat-card__label">Lbs Donated</span>
    </div>
  </div>
  <div class="stat-card stat-card--garden">
    <div class="stat-card__info">
      <span class="stat-card__value"><%= Number(stats.totalHrs).toFixed(1) %></span>
      <span class="stat-card__label">Volunteer Hours</span>
    </div>
  </div>
  <div class="stat-card stat-card--garden">
    <div class="stat-card__info">
      <span class="stat-card__value">#<%= stats.harvestRank %></span>
      <span class="stat-card__label">Harvest Rank (of <%= stats.totalGardeners %>)</span>
    </div>
  </div>
  <div class="stat-card stat-card--garden">
    <div class="stat-card__info">
      <span class="stat-card__value"><%= stats.awardCount %></span>
      <span class="stat-card__label">Awards</span>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div style="display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap">
  <a href="/member/log-harvest" class="btn btn--primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Log Harvest
  </a>
  <a href="/member/log-hours" class="btn btn--ghost">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    Log Hours
  </a>
</div>

<% if (awards.length > 0) { %>
<div class="card" style="margin-bottom:1.5rem">
  <div class="card__header"><h2 class="card__title">My Awards</h2></div>
  <div class="card__body">
    <% awards.forEach(a => { %>
      <div class="award-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        <div>
          <strong><%= a.award_name %></strong>
          <span class="text-muted"> &mdash; <%= a.category %><%= a.season_name ? ' (' + a.season_name + ')' : '' %></span>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<div class="dashboard-grid">
  <div class="card">
    <div class="card__header"><h2 class="card__title">Recent Harvests</h2></div>
    <div class="card__body">
      <% if (recentHarvests.length === 0) { %>
        <p class="empty-state">No harvests logged yet.</p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>Date</th><th>Crop</th><th>Lbs</th><th>Donated To</th></tr></thead>
          <tbody>
            <% recentHarvests.forEach(h => { %>
              <tr>
                <td><%= h.harvest_date %></td>
                <td><%= h.crop %></td>
                <td><strong><%= h.pounds %></strong></td>
                <td><%= h.donated_to || (h.donated ? 'Yes' : '—') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card__header"><h2 class="card__title">Recent Hours</h2></div>
    <div class="card__body">
      <% if (recentHours.length === 0) { %>
        <p class="empty-state">No hours logged yet.</p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>Date</th><th>Hours</th><th>Activity</th></tr></thead>
          <tbody>
            <% recentHours.forEach(h => { %>
              <tr>
                <td><%= h.work_date %></td>
                <td><strong><%= h.hours %></strong></td>
                <td><%= h.activity || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

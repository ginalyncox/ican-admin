<div class="page-header">
  <div class="page-header__row">
    <h1 class="page-header__title">Log a Harvest</h1>
    <a href="/member" class="btn btn--ghost">Back to Dashboard</a>
  </div>
</div>

<div class="card" style="max-width: 600px">
  <div class="card__body">
    <form method="POST" action="/member/log-harvest">
      <% if (seasons.length > 0) { %>
      <div class="form-field">
        <label for="season_id">Season</label>
        <select id="season_id" name="season_id" class="form-select">
          <% seasons.forEach(s => { %>
            <option value="<%= s.id %>" <%= gardener.season_id == s.id ? 'selected' : '' %>><%= s.name %> (<%= s.year %>)</option>
          <% }) %>
        </select>
      </div>
      <% } %>

      <div class="form-row">
        <div class="form-field">
          <label for="harvest_date">Harvest Date</label>
          <input type="date" id="harvest_date" name="harvest_date" class="form-input" value="<%= new Date().toISOString().split('T')[0] %>" required>
        </div>
        <div class="form-field">
          <label for="crop">Crop</label>
          <input type="text" id="crop" name="crop" class="form-input" placeholder="e.g. Tomatoes" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-field">
          <label for="pounds">Pounds Harvested</label>
          <input type="number" id="pounds" name="pounds" class="form-input" step="0.1" min="0.1" max="500" required placeholder="0.0">
        </div>
        <div class="form-field">
          <label for="donated_to">Donated To</label>
          <input type="text" id="donated_to" name="donated_to" class="form-input" placeholder="e.g. Local Food Pantry">
        </div>
      </div>

      <div class="form-field">
        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer">
          <input type="checkbox" name="donated" value="1">
          This harvest was donated
        </label>
      </div>

      <div class="form-field">
        <label for="notes">Notes (optional)</label>
        <textarea id="notes" name="notes" class="form-input" rows="3" placeholder="Any additional details..."></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Log Harvest</button>
        <a href="/member" class="btn btn--ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

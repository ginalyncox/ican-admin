<div class="page-header">
  <div class="page-header__row">
    <h1 class="page-header__title">Volunteer Hours</h1>
    <a href="/admin/garden/hours/new" class="btn btn--primary">Log Hours</a>
  </div>
</div>

<div class="filters">
  <form method="GET" action="/admin/garden/hours" class="filters__form">
    <select name="gardener" class="form-select form-select--sm" onchange="this.form.submit()">
      <option value="">All Gardeners</option>
      <% gardeners.forEach(g => { %>
        <option value="<%= g.id %>" <%= filters.gardener == g.id ? 'selected' : '' %>><%= g.last_name %>, <%= g.first_name %></option>
      <% }) %>
    </select>
    <select name="season" class="form-select form-select--sm" onchange="this.form.submit()">
      <option value="">All Seasons</option>
      <% seasons.forEach(s => { %>
        <option value="<%= s.id %>" <%= filters.season == s.id ? 'selected' : '' %>><%= s.name %></option>
      <% }) %>
    </select>
  </form>
</div>

<% if (entries.length === 0) { %>
  <div class="card"><div class="card__body"><p class="empty-state">No hours logged yet.</p></div></div>
<% } else { %>
  <div class="card"><div class="card__body">
    <table class="table">
      <thead><tr><th>Date</th><th>Gardener</th><th>Hours</th><th>Activity</th><th>Season</th><th></th></tr></thead>
      <tbody>
        <% entries.forEach(e => { %>
          <tr>
            <td><%= e.work_date %></td>
            <td><a href="/admin/garden/gardeners/<%= e.gardener_id %>"><%= e.first_name %> <%= e.last_name %></a></td>
            <td><strong><%= e.hours %></strong></td>
            <td><%= e.activity || '—' %></td>
            <td><%= e.season_name || '—' %></td>
            <td class="table__actions">
              <form method="POST" action="/admin/garden/hours/<%= e.id %>/delete" onsubmit="return confirm('Delete?')" style="display:inline">
                <button type="submit" class="btn btn--danger btn--xs">&times;</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>
<% } %>

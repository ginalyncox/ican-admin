<div class="page-header">
  <div class="page-header__row">
    <h1 class="page-header__title">Volunteers</h1>
    <div class="page-header__actions">
      <a href="/admin/garden/export/gardeners" class="btn btn--outline btn--sm">Export CSV</a>
      <a href="/admin/garden/gardeners/new" class="btn btn--primary">Add Volunteer</a>
    </div>
  </div>
</div>

<div class="filters">
  <form method="GET" action="/admin/garden/gardeners" class="filters__form">
    <select name="season" class="form-select form-select--sm" onchange="this.form.submit()">
      <option value="">All Seasons</option>
      <% seasons.forEach(s => { %>
        <option value="<%= s.id %>" <%= filters.season == s.id ? 'selected' : '' %>><%= s.name %> (<%= s.year %>)</option>
      <% }) %>
    </select>
    <select name="status" class="form-select form-select--sm" onchange="this.form.submit()">
      <option value="">All Statuses</option>
      <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
      <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
      <option value="waitlist" <%= filters.status === 'waitlist' ? 'selected' : '' %>>Waitlist</option>
    </select>
  </form>
</div>

<!-- Bulk Actions Bar -->
<div class="bulk-bar" id="bulkBar">
  <span class="bulk-bar__count"><span id="bulkCount">0</span> selected</span>
  <form method="POST" action="/admin/garden/gardeners/bulk/assign" id="bulkAssignForm" style="display: inline;">
    <input type="hidden" name="ids" id="bulkAssignIds">
    <select name="program" class="form-control" style="width: auto; font-size: 0.8rem; padding: 0.25rem 0.5rem; background: rgba(255,255,255,0.15); color: #fff; border-color: rgba(255,255,255,0.3);">
      <option value="victory_garden">Victory Garden</option>
      <option value="legislative">Legislative Action</option>
      <option value="outreach">Community Outreach</option>
      <option value="fundraising">Fundraising</option>
      <option value="communications">Communications</option>
      <option value="membership">Membership</option>
    </select>
    <button type="submit" class="btn">Assign to Program</button>
  </form>
  <form method="POST" action="/admin/garden/gardeners/bulk/create-accounts" id="bulkAccountsForm" style="display: inline;">
    <input type="hidden" name="ids" id="bulkAccountIds">
    <button type="submit" class="btn">Create Portal Accounts</button>
  </form>
  <a href="#" id="bulkExportLink" class="btn">Export Selected</a>
</div>

<% if (gardeners.length === 0) { %>
  <div class="card"><div class="card__body"><p class="empty-state">No volunteers found. <a href="/admin/garden/gardeners/new">Add your first volunteer</a></p></div></div>
<% } else { %>
  <div class="card"><div class="card__body">
    <table class="table">
      <thead><tr>
        <th style="width: 30px;"><input type="checkbox" id="selectAll" title="Select all"></th>
        <th>Name</th><th>Email</th><th>Site</th><th>Plot</th><th>Season</th><th>Status</th><th></th>
      </tr></thead>
      <tbody>
        <% gardeners.forEach(g => { %>
          <tr>
            <td><input type="checkbox" class="vol-check" value="<%= g.id %>" data-name="<%= g.first_name %> <%= g.last_name %>"></td>
            <td><a href="/admin/garden/gardeners/<%= g.id %>"><strong><%= g.last_name %>, <%= g.first_name %></strong></a></td>
            <td class="text-muted"><%= g.email || '—' %></td>
            <td><%= g.site_name || '—' %></td>
            <td><%= g.plot_number || '—' %></td>
            <td><%= g.season_name || '—' %></td>
            <td><span class="badge badge--<%= g.status %>"><%= g.status %></span></td>
            <td class="table__actions">
              <a href="/admin/garden/gardeners/<%= g.id %>/edit" class="btn btn--outline btn--xs">Edit</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>
<% } %>

<script>
(function() {
  const checks = document.querySelectorAll('.vol-check');
  const selectAll = document.getElementById('selectAll');
  const bar = document.getElementById('bulkBar');
  const countEl = document.getElementById('bulkCount');

  function update() {
    const selected = document.querySelectorAll('.vol-check:checked');
    const ids = Array.from(selected).map(c => c.value).join(',');
    countEl.textContent = selected.length;
    bar.classList.toggle('active', selected.length > 0);
    document.getElementById('bulkAssignIds').value = ids;
    document.getElementById('bulkAccountIds').value = ids;
    document.getElementById('bulkExportLink').href = '/admin/garden/export/gardeners?ids=' + ids;
  }

  selectAll.addEventListener('change', function() {
    checks.forEach(c => c.checked = this.checked);
    update();
  });
  checks.forEach(c => c.addEventListener('change', update));
})();
</script>

<div class="page-header">
  <div class="page-header__row">
    <div>
      <h1 class="page-header__title">Victory Garden</h1>
      <p class="page-header__subtitle">
        <% if (activeSeason) { %>
          <%= activeSeason.name %> &mdash; <%= activeSeason.year %>
        <% } else { %>
          No active season
        <% } %>
      </p>
    </div>
    <div class="page-header__actions">
      <a href="/admin/garden/seasons" class="btn btn--outline btn--sm">Manage Seasons</a>
    </div>
  </div>
</div>

<div class="stats-grid stats-grid--5">
  <div class="stat-card stat-card--garden">
    <div class="stat-card__icon stat-card__icon--gardeners">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= stats.totalGardeners %></span>
      <span class="stat-card__label">Active Gardeners</span>
    </div>
  </div>
  <div class="stat-card stat-card--garden">
    <div class="stat-card__icon stat-card__icon--sites">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= stats.totalSites %></span>
      <span class="stat-card__label">Garden Sites</span>
    </div>
  </div>
  <div class="stat-card stat-card--garden">
    <div class="stat-card__icon stat-card__icon--harvest">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= Number(stats.totalHarvestLbs).toFixed(1) %></span>
      <span class="stat-card__label">Lbs Harvested</span>
    </div>
  </div>
  <div class="stat-card stat-card--garden">
    <div class="stat-card__icon stat-card__icon--donated">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= Number(stats.totalDonatedLbs).toFixed(1) %></span>
      <span class="stat-card__label">Lbs Donated</span>
    </div>
  </div>
  <div class="stat-card stat-card--garden">
    <div class="stat-card__icon stat-card__icon--hours">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <div class="stat-card__info">
      <span class="stat-card__value"><%= Number(stats.totalVolunteerHrs).toFixed(1) %></span>
      <span class="stat-card__label">Volunteer Hours</span>
    </div>
  </div>
</div>

<div class="garden-nav-grid">
  <a href="/admin/garden/gardeners" class="garden-nav-card">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    <span>Gardeners</span>
  </a>
  <a href="/admin/garden/sites" class="garden-nav-card">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
    <span>Sites</span>
  </a>
  <a href="/admin/garden/harvests" class="garden-nav-card">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a10 10 0 0 1 10 10c0 5.5-10 12-10 12S2 17.5 2 12A10 10 0 0 1 12 2z"/><path d="M12 6v8"/><path d="M8 10l4-4 4 4"/></svg>
    <span>Harvests</span>
  </a>
  <a href="/admin/garden/hours" class="garden-nav-card">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    <span>Hours</span>
  </a>
  <a href="/admin/garden/verify" class="garden-nav-card garden-nav-card--accent">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <span>Verify Donations</span>
  </a>
  <a href="/admin/garden/donations" class="garden-nav-card">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    <span>Donation Report</span>
  </a>
  <a href="/admin/garden/leaderboard" class="garden-nav-card">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9H2v12h4V9zM14 4h-4v17h4V4zM22 14h-4v7h4v-7z"/></svg>
    <span>Leaderboard</span>
  </a>
  <a href="/admin/garden/awards" class="garden-nav-card">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
    <span>Awards</span>
  </a>
  <a href="/admin/garden/members" class="garden-nav-card">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    <span>Member Logins</span>
  </a>
</div>

<div class="dashboard-grid">
  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Top Harvesters</h2>
      <a href="/admin/garden/leaderboard" class="card__link">Full leaderboard</a>
    </div>
    <div class="card__body">
      <% if (topHarvesters.length === 0) { %>
        <p class="empty-state">No harvest data yet.</p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>#</th><th>Gardener</th><th>Lbs</th></tr></thead>
          <tbody>
            <% topHarvesters.forEach((g, i) => { %>
              <tr>
                <td><span class="rank-badge rank-badge--<%= i+1 %>"><%= i+1 %></span></td>
                <td><%= g.first_name %> <%= g.last_name %></td>
                <td><strong><%= Number(g.total_lbs).toFixed(1) %></strong></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card__header">
      <h2 class="card__title">Top Volunteers</h2>
      <a href="/admin/garden/leaderboard" class="card__link">Full leaderboard</a>
    </div>
    <div class="card__body">
      <% if (topVolunteers.length === 0) { %>
        <p class="empty-state">No volunteer hours yet.</p>
      <% } else { %>
        <table class="table">
          <thead><tr><th>#</th><th>Gardener</th><th>Hrs</th></tr></thead>
          <tbody>
            <% topVolunteers.forEach((g, i) => { %>
              <tr>
                <td><span class="rank-badge rank-badge--<%= i+1 %>"><%= i+1 %></span></td>
                <td><%= g.first_name %> <%= g.last_name %></td>
                <td><strong><%= Number(g.total_hrs).toFixed(1) %></strong></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

<div class="page-header">
  <h1 class="page-header__title"><%= isNew ? 'Add Volunteer' : 'Edit Volunteer' %></h1>
</div>

<div class="card" style="max-width: 640px;">
  <div class="card__body">
    <form method="POST" action="<%= isNew ? '/admin/garden/gardeners' : '/admin/garden/gardeners/' + gardener.id %>">
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="first_name">First Name</label>
          <input class="form-input" type="text" id="first_name" name="first_name" value="<%= gardener.first_name %>" required>
        </div>
        <div class="form-field">
          <label class="form-label" for="last_name">Last Name</label>
          <input class="form-input" type="text" id="last_name" name="last_name" value="<%= gardener.last_name %>" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" value="<%= gardener.email || '' %>">
        </div>
        <div class="form-field">
          <label class="form-label" for="phone">Phone</label>
          <input class="form-input" type="tel" id="phone" name="phone" value="<%= gardener.phone || '' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="site_id">Garden Site</label>
          <select class="form-select" id="site_id" name="site_id">
            <option value="">— Select —</option>
            <% sites.forEach(s => { %>
              <option value="<%= s.id %>" <%= gardener.site_id == s.id ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-field">
          <label class="form-label" for="plot_number">Plot #</label>
          <input class="form-input" type="text" id="plot_number" name="plot_number" value="<%= gardener.plot_number || '' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="season_id">Season</label>
          <select class="form-select" id="season_id" name="season_id">
            <option value="">— Select —</option>
            <% seasons.forEach(s => { %>
              <option value="<%= s.id %>" <%= gardener.season_id == s.id ? 'selected' : '' %>><%= s.name %> (<%= s.year %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="form-field">
          <label class="form-label" for="status">Status</label>
          <select class="form-select" id="status" name="status">
            <option value="active" <%= gardener.status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="inactive" <%= gardener.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
            <option value="waitlist" <%= gardener.status === 'waitlist' ? 'selected' : '' %>>Waitlist</option>
          </select>
        </div>
      </div>
      <div class="form-field">
        <label class="form-label" for="notes">Notes</label>
        <textarea class="form-input" id="notes" name="notes" rows="3"><%= gardener.notes || '' %></textarea>
      </div>

      <hr style="margin: 1rem 0; border-color: var(--color-border);">
      <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">Volunteer Profile</h3>

      <div class="form-field">
        <label class="form-label" for="address">Street Address</label>
        <input class="form-input" type="text" id="address" name="address" value="<%= gardener.address || '' %>">
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="city">City</label>
          <input class="form-input" type="text" id="city" name="city" value="<%= gardener.city || '' %>">
        </div>
        <div class="form-field">
          <label class="form-label" for="state">State</label>
          <input class="form-input" type="text" id="state" name="state" value="<%= gardener.state || '' %>" maxlength="2" placeholder="IA">
        </div>
        <div class="form-field">
          <label class="form-label" for="zip">ZIP</label>
          <input class="form-input" type="text" id="zip" name="zip" value="<%= gardener.zip || '' %>" maxlength="10">
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="date_of_birth">Date of Birth</label>
          <input class="form-input" type="date" id="date_of_birth" name="date_of_birth" value="<%= gardener.date_of_birth || '' %>">
        </div>
        <div class="form-field">
          <label class="form-label" for="tshirt_size">T-Shirt Size</label>
          <select class="form-select" id="tshirt_size" name="tshirt_size">
            <option value="">— Select —</option>
            <% ['XS','S','M','L','XL','2XL','3XL'].forEach(sz => { %>
              <option value="<%= sz %>" <%= (gardener.tshirt_size || '') === sz ? 'selected' : '' %>><%= sz %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <h4 style="font-size: 0.9rem; margin: 1rem 0 0.5rem; color: var(--color-muted);">Emergency Contact</h4>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="emergency_contact_name">Name</label>
          <input class="form-input" type="text" id="emergency_contact_name" name="emergency_contact_name" value="<%= gardener.emergency_contact_name || '' %>">
        </div>
        <div class="form-field">
          <label class="form-label" for="emergency_contact_phone">Phone</label>
          <input class="form-input" type="tel" id="emergency_contact_phone" name="emergency_contact_phone" value="<%= gardener.emergency_contact_phone || '' %>">
        </div>
      </div>

      <div class="form-field">
        <label class="form-label" for="how_heard">How Did They Hear About Us?</label>
        <input class="form-input" type="text" id="how_heard" name="how_heard" value="<%= gardener.how_heard || '' %>">
      </div>
      <div class="form-field">
        <label class="form-label" for="skills">Skills &amp; Interests</label>
        <textarea class="form-input" id="skills" name="skills" rows="2" placeholder="Gardening, event planning, writing..."><%= gardener.skills || '' %></textarea>
      </div>
      <div class="form-field">
        <label class="form-label" for="availability">Availability</label>
        <textarea class="form-input" id="availability" name="availability" rows="2" placeholder="Weekends, evenings, etc."><%= gardener.availability || '' %></textarea>
      </div>

      <h4 style="font-size: 0.9rem; margin: 1rem 0 0.5rem; color: var(--color-muted);">Consents &amp; Waivers</h4>
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <label style="display:flex; align-items:center; gap:0.5rem; font-weight:normal; cursor:pointer; font-size:0.9rem;">
          <input type="checkbox" name="background_check_consent" value="1" <%= gardener.background_check_consent ? 'checked' : '' %>>
          Background Check Consent
        </label>
        <label style="display:flex; align-items:center; gap:0.5rem; font-weight:normal; cursor:pointer; font-size:0.9rem;">
          <input type="checkbox" name="photo_release_consent" value="1" <%= gardener.photo_release_consent ? 'checked' : '' %>>
          Photo Release Consent
        </label>
        <label style="display:flex; align-items:center; gap:0.5rem; font-weight:normal; cursor:pointer; font-size:0.9rem;">
          <input type="checkbox" name="liability_waiver_signed" value="1" <%= gardener.liability_waiver_signed ? 'checked' : '' %>>
          Liability Waiver Signed
        </label>
      </div>

      <hr style="margin: 1rem 0; border-color: var(--color-border);">
      <div class="form-field">
        <label class="form-label">Volunteer Programs</label>
        <p style="font-size: 0.8rem; color: var(--color-muted); margin-bottom: 0.75rem;">Assign this volunteer to one or more programs.</p>
        <% const allPrograms = [
          { key: 'victory_garden', label: 'Victory Garden' },
          { key: 'legislative', label: 'Legislative Action' },
          { key: 'outreach', label: 'Community Outreach' },
          { key: 'fundraising', label: 'Fundraising' },
          { key: 'communications', label: 'Communications' },
          { key: 'membership', label: 'Membership' }
        ]; %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
          <% allPrograms.forEach(p => { %>
            <label style="display:flex; align-items:center; gap:0.5rem; font-weight:normal; cursor:pointer; font-size:0.9rem;">
              <input type="checkbox" name="programs" value="<%= p.key %>" <%= (typeof programs !== 'undefined' && programs.includes(p.key)) ? 'checked' : '' %>>
              <%= p.label %>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary"><%= isNew ? 'Add Volunteer' : 'Update Volunteer' %></button>
        <a href="/admin/garden/gardeners" class="btn btn--outline">Cancel</a>
      </div>
    </form>
  </div>
</div>

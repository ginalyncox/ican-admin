<div class="page-header">
  <h1 class="page-header__title">Log Volunteer Hours</h1>
</div>

<%
const PROG_LABELS = {
  victory_garden: 'Victory Garden',
  legislative: 'Legislative Action',
  outreach: 'Community Outreach',
  fundraising: 'Fundraising',
  communications: 'Communications',
  membership: 'Membership'
};
%>

<div class="card" style="max-width: 640px;">
  <div class="card__body">
    <form method="POST" action="/admin/garden/hours">
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="gardener_id">Volunteer</label>
          <select class="form-select" id="gardener_id" name="gardener_id" required>
            <option value="">— Select —</option>
            <% gardeners.forEach(g => { %>
              <option value="<%= g.id %>" <%= entry.gardener_id == g.id ? 'selected' : '' %>><%= g.last_name %>, <%= g.first_name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-field">
          <label class="form-label" for="program">Program</label>
          <select class="form-select" id="program" name="program" required onchange="document.getElementById('season-row').style.display = this.value === 'victory_garden' ? '' : 'none';">
            <% Object.entries(PROG_LABELS).forEach(([k, v]) => { %>
              <option value="<%= k %>" <%= (entry.program || 'victory_garden') === k ? 'selected' : '' %>><%= v %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="form-row" id="season-row" style="<%= (entry.program && entry.program !== 'victory_garden') ? 'display:none' : '' %>">
        <div class="form-field">
          <label class="form-label" for="season_id">Season <span style="font-weight:normal; color:var(--color-muted);">(Victory Garden)</span></label>
          <select class="form-select" id="season_id" name="season_id">
            <option value="">— None —</option>
            <% seasons.forEach(s => { %>
              <option value="<%= s.id %>" <%= entry.season_id == s.id ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="work_date">Date</label>
          <input class="form-input" type="date" id="work_date" name="work_date" value="<%= entry.work_date %>" required>
        </div>
        <div class="form-field">
          <label class="form-label" for="hours">Hours</label>
          <input class="form-input" type="number" id="hours" name="hours" value="<%= entry.hours %>" step="0.25" min="0.25" required>
        </div>
      </div>
      <div class="form-field">
        <label class="form-label" for="activity">Activity</label>
        <input class="form-input" type="text" id="activity" name="activity" value="<%= entry.activity || '' %>" placeholder="e.g. Weeding, planting, watering">
      </div>
      <div class="form-field">
        <label class="form-label" for="notes">Notes</label>
        <textarea class="form-input" id="notes" name="notes" rows="2"><%= entry.notes || '' %></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Log Hours</button>
        <a href="/admin/garden/hours" class="btn btn--outline">Cancel</a>
      </div>
    </form>
  </div>
</div>
